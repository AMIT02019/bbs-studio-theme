{% doc %}
  @prompt
    Header Layout (Important)
    
    The header must contain:
    
    Left side: Section title (default: “BEST SELLER”)
    
    Right side: “VIEW ALL” button
    
    A decorative line placed between the title and the button, expanding to fill the remaining horizontal space.
    
    Header structure:
    
    display: flex
    
    align-items: center
    
    gap: 20px
    
    Layout structure:
    
    [ Title ] —— flexible divider line —— [ View All Button ]
    
    The divider line must:
    
    Use flex-grow: 1
    
    Sit between title and button
    
    Be vertically centered
    
    Adjust automatically to screen width
    
    Divider Line Customization (Required)
    
    Add settings inside Shopify schema:
    
    Toggle: Show / Hide header divider line
    
    Line style selector:
    
    Solid
    
    Dashed
    
    Dotted
    
    Striped (angled repeating gradient)
    
    Line color picker
    
    Line thickness control (1px–6px)
    
    Divider must support:
    
    Solid using background-color
    
    Dashed using border-top
    
    Dotted using border-top
    
    Striped using repeating-linear-gradient
    
    View All Button
    
    Positioned at right side of header
    
    Links automatically to selected collection
    
    Clean minimal style
    
    Default primary color: red (#e10600)
    
    Add customization settings:
    
    Primary border color
    
    Text color
    
    Hover background color
    
    Hover text color
    
    Border radius
    
    Default behavior:
    
    Outline style (red text + red border)
    
    On hover → background changes to hover color
    
    Text changes to hover text color
    
    Responsive Behavior
    
    On mobile:
    
    Header stacks vertically
    
    Title on top
    
    Divider hidden OR full width below title (configurable)
    
    Button below title
    
    Collection Integration
    
    Collection picker setting
    
    Dynamic product loading
    
    Product limit control
    
    Reusable for BEST SELLER, NEW ARRIVAL, TRENDING, etc.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-showcase-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-collection-showcase-header-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: {{ block.settings.header_margin_bottom }}px;
  }

  .ai-collection-showcase-title-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: {{ block.settings.title_font_weight }};
    color: {{ block.settings.title_color }};
    text-transform: {{ block.settings.title_text_transform }};
    white-space: nowrap;
  }

  .ai-collection-showcase-divider-{{ ai_gen_id }} {
    flex-grow: 1;
    height: {{ block.settings.divider_thickness }}px;
    {% if block.settings.divider_style == 'solid' %}
      background-color: {{ block.settings.divider_color }};
    {% elsif block.settings.divider_style == 'dashed' %}
      border-top: {{ block.settings.divider_thickness }}px dashed {{ block.settings.divider_color }};
      height: 0;
    {% elsif block.settings.divider_style == 'dotted' %}
      border-top: {{ block.settings.divider_thickness }}px dotted {{ block.settings.divider_color }};
      height: 0;
    {% elsif block.settings.divider_style == 'striped' %}
      background: repeating-linear-gradient(
        45deg,
        {{ block.settings.divider_color }},
        {{ block.settings.divider_color }} 10px,
        transparent 10px,
        transparent 20px
      );
    {% endif %}
  }

  .ai-collection-showcase-view-all-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-transform: {{ block.settings.button_text_transform }};
    color: {{ block.settings.button_text_color }};
    background-color: transparent;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.3s ease;
  }

  .ai-collection-showcase-view-all-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_bg_color }};
  }

  .ai-collection-showcase-products-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.products_per_row }}, 1fr);
    gap: {{ block.settings.product_gap }}px;
  }

  .ai-collection-showcase-product-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-collection-showcase-product-image-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    margin-bottom: 12px;
    overflow: hidden;
    border-radius: {{ block.settings.product_image_radius }}px;
  }

  .ai-collection-showcase-product-image-{{ ai_gen_id }} img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-collection-showcase-product-title-{{ ai_gen_id }} {
    font-size: 14px;
    margin: 0 0 8px;
    color: {{ block.settings.product_title_color }};
  }

  .ai-collection-showcase-product-title-{{ ai_gen_id }} a {
    color: inherit;
    text-decoration: none;
  }

  .ai-collection-showcase-product-title-{{ ai_gen_id }} a:hover {
    opacity: 0.7;
  }

  .ai-collection-showcase-product-price-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 600;
    color: {{ block.settings.product_price_color }};
  }

  .ai-collection-showcase-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #999;
    font-style: italic;
  }

  @media screen and (max-width: 749px) {
    .ai-collection-showcase-header-{{ ai_gen_id }} {
      {% if block.settings.mobile_header_stack %}
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
      {% endif %}
    }

    .ai-collection-showcase-divider-{{ ai_gen_id }} {
      {% if block.settings.mobile_header_stack %}
        {% if block.settings.mobile_divider_full_width %}
          width: 100%;
        {% else %}
          display: none;
        {% endif %}
      {% endif %}
    }

    .ai-collection-showcase-products-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.products_per_row_mobile }}, 1fr);
    }

    .ai-collection-showcase-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<div class="ai-collection-showcase-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-collection-showcase-header-{{ ai_gen_id }}">
    <h2 class="ai-collection-showcase-title-{{ ai_gen_id }}">
      {{ block.settings.section_title }}
    </h2>

    {% if block.settings.show_divider %}
      <div class="ai-collection-showcase-divider-{{ ai_gen_id }}"></div>
    {% endif %}

    {% if block.settings.collection != blank %}
      <a
        href="{{ block.settings.collection.url }}"
        class="ai-collection-showcase-view-all-{{ ai_gen_id }}"
      >
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>

  {% if block.settings.collection != blank %}
    <div class="ai-collection-showcase-products-{{ ai_gen_id }}">
      {% for product in block.settings.collection.products limit: block.settings.product_limit %}
        <div class="ai-collection-showcase-product-{{ ai_gen_id }}">
          <div class="ai-collection-showcase-product-image-{{ ai_gen_id }}">
            {% if product.featured_image %}
              <img
                src="{{ product.featured_image | image_url: width: 600 }}"
                alt="{{ product.featured_image.alt | escape }}"
                loading="lazy"
                width="600"
                height="600"
              >
            {% else %}
              {{ 'product-1' | placeholder_svg_tag }}
            {% endif %}
          </div>
          <h3 class="ai-collection-showcase-product-title-{{ ai_gen_id }}">
            <a href="{{ product.url }}">{{ product.title }}</a>
          </h3>
          <div class="ai-collection-showcase-product-price-{{ ai_gen_id }}">
            {{ product.price | money }}
          </div>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <div class="ai-collection-showcase-empty-{{ ai_gen_id }}">
      Select a collection to display products
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Collection showcase",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "product_limit",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Products to show",
      "default": 4
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Header layout"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Section title",
      "default": "BEST SELLER"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "min": 14,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 24
    },
    {
      "type": "select",
      "id": "title_font_weight",
      "label": "Title weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "title_text_transform",
      "label": "Title transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "uppercase"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "header_margin_bottom",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "label": "Header spacing",
      "default": 30
    },
    {
      "type": "header",
      "content": "Divider line"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show divider line",
      "default": true
    },
    {
      "type": "select",
      "id": "divider_style",
      "label": "Line style",
      "options": [
        { "value": "solid", "label": "Solid" },
        { "value": "dashed", "label": "Dashed" },
        { "value": "dotted", "label": "Dotted" },
        { "value": "striped", "label": "Striped" }
      ],
      "default": "solid"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Line color",
      "default": "#cccccc"
    },
    {
      "type": "range",
      "id": "divider_thickness",
      "min": 1,
      "max": 6,
      "step": 1,
      "unit": "px",
      "label": "Line thickness",
      "default": 1
    },
    {
      "type": "header",
      "content": "View all button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "VIEW ALL"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 14
    },
    {
      "type": "select",
      "id": "button_font_weight",
      "label": "Font weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "select",
      "id": "button_text_transform",
      "label": "Text transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "uppercase"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#e10600"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Border color",
      "default": "#e10600"
    },
    {
      "type": "range",
      "id": "button_border_width",
      "min": 1,
      "max": 4,
      "step": 1,
      "unit": "px",
      "label": "Border width",
      "default": 1
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "Hover background",
      "default": "#e10600"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Hover text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 0
    },
    {
      "type": "range",
      "id": "button_padding_vertical",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Vertical padding",
      "default": 8
    },
    {
      "type": "range",
      "id": "button_padding_horizontal",
      "min": 10,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 20
    },
    {
      "type": "header",
      "content": "Mobile layout"
    },
    {
      "type": "checkbox",
      "id": "mobile_header_stack",
      "label": "Stack header on mobile",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "mobile_divider_full_width",
      "label": "Full width divider on mobile",
      "default": true,
      "info": "Only applies when header is stacked"
    },
    {
      "type": "header",
      "content": "Product grid"
    },
    {
      "type": "range",
      "id": "products_per_row",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Products per row (desktop)",
      "default": 4
    },
    {
      "type": "range",
      "id": "products_per_row_mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Products per row (mobile)",
      "default": 2
    },
    {
      "type": "range",
      "id": "product_gap",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Gap between products",
      "default": 20
    },
    {
      "type": "range",
      "id": "product_image_radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Image border radius",
      "default": 0
    },
    {
      "type": "color",
      "id": "product_title_color",
      "label": "Product title color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "product_price_color",
      "label": "Product price color",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Collection showcase"
    }
  ]
}
{% endschema %}
