{% doc %}
  @prompt
    create a collection list i want to call all the authores in one row i want five crds or more in this card first i wnt image and then name about author and them view all books button, no i have one specific collection i want to call the collection so all the collection wil automeacaly come i don't want to manualy  select the collection each time.
    ther should not be a limit for shuold  in a section
    and I can remove or add manually also the collection
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-author-list-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-author-list__container-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-author-list__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.card_spacing }}px;
    width: 100%;
  }

  .ai-author-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: {{ block.settings.card_inner_spacing }}px;
  }

  .ai-author-card-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .ai-author-card__image-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.image_size }}px;
    height: {{ block.settings.image_size }}px;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .ai-author-card__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-author-card__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.placeholder_background }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-author-card__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-author-card__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_spacing }}px;
    width: 100%;
  }

  .ai-author-card__name-{{ ai_gen_id }} {
    font-size: {{ block.settings.name_font_size }}px;
    font-weight: {{ block.settings.name_font_weight }};
    color: {{ block.settings.name_color }};
    margin: 0;
    line-height: 1.3;
  }

  .ai-author-card__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: {{ block.settings.description_lines }};
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ai-author-card__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    transition: background-color 0.3s ease, color 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-author-card__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-author-list__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-author-list__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-author-card__image-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.image_size | times: 0.8 }}px;
      height: {{ block.settings.image_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<author-collection-list-{{ ai_gen_id }}
  class="ai-author-list-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-author-list__container-{{ ai_gen_id }}">
    <div class="ai-author-list__grid-{{ ai_gen_id }}">
      {% liquid
        if block.settings.auto_load_collections
          assign all_collections = collections
        else
          assign all_collections = block.settings.manual_collections
        endif
      %}

      {% for collection in all_collections %}
        <div class="ai-author-card-{{ ai_gen_id }}">
          <div class="ai-author-card__image-wrapper-{{ ai_gen_id }}">
            {% if collection.image %}
              <img
                src="{{ collection.image | image_url: width: 400 }}"
                alt="{{ collection.title | escape }}"
                class="ai-author-card__image-{{ ai_gen_id }}"
                loading="lazy"
                width="400"
                height="400"
              >
            {% elsif collection.products.first.featured_image %}
              <img
                src="{{ collection.products.first.featured_image | image_url: width: 400 }}"
                alt="{{ collection.title | escape }}"
                class="ai-author-card__image-{{ ai_gen_id }}"
                loading="lazy"
                width="400"
                height="400"
              >
            {% else %}
              <div class="ai-author-card__image-placeholder-{{ ai_gen_id }}">
                {{ 'collection-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <div class="ai-author-card__content-{{ ai_gen_id }}">
            <h3 class="ai-author-card__name-{{ ai_gen_id }}">
              {{ collection.title }}
            </h3>

            {% if collection.description != blank %}
              <div class="ai-author-card__description-{{ ai_gen_id }}">
                {{ collection.description | strip_html }}
              </div>
            {% endif %}

            <a
              href="{{ collection.url }}"
              class="ai-author-card__button-{{ ai_gen_id }}"
            >
              {{ block.settings.button_text }}
            </a>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</author-collection-list-{{ ai_gen_id }}>

<script>
  (function() {
    class AuthorCollectionList{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('author-collection-list-{{ ai_gen_id }}', AuthorCollectionList{{ ai_gen_id }});
  })();
</script>

