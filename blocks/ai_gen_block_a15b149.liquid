{% doc %}
  @prompt
    <section class="recent-products">
      <div class="page-width">
        <h2>Recently Added Products</h2>
    
        <div class="recent-products-grid">
          {% assign recent_products = collections.all.products | sort: 'created_at' | reverse %}
    
          {% for product in recent_products limit: 8 %}
            <a href="{{ product.url }}" class="product-card">
    
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.title }}"
                  width="600"
                  height="600"
                >
              {% endif %}
    
              <h3>{{ product.title }}</h3>
    
              <div class="price">
                {{ product.price | money }}
              </div>
    
            </a>
          {% endfor %}
        </div>
      </div>
    </section>
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-recent-products-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
  }

  .ai-recent-products-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-recent-products-heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-recent-products-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-recent-product-card-{{ ai_gen_id }} {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease;
  }

  .ai-recent-product-card-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
  }

  .ai-recent-product-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    background-color: {{ block.settings.image_background_color }};
    margin-bottom: {{ block.settings.image_margin_bottom }}px;
  }

  .ai-recent-product-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-recent-product-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-recent-product-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-recent-product-title-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.title_margin_bottom }}px;
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    font-weight: {{ block.settings.title_font_weight }};
  }

  .ai-recent-product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: {{ block.settings.price_font_weight }};
  }

  @media screen and (max-width: 989px) {
    .ai-recent-products-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-recent-products-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-recent-products-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }
  }
{% endstyle %}

<recent-products-{{ ai_gen_id }} class="ai-recent-products-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-recent-products-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-recent-products-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-recent-products-grid-{{ ai_gen_id }}">
      {% assign recent_products = collections.all.products | sort: 'created_at' | reverse %}

      {% for product in recent_products limit: block.settings.products_to_show %}
        <a href="{{ product.url }}" class="ai-recent-product-card-{{ ai_gen_id }}">
          <div class="ai-recent-product-image-wrapper-{{ ai_gen_id }}">
            {% if product.featured_image %}
              <img
                src="{{ product.featured_image | image_url: width: 600 }}"
                alt="{{ product.title | escape }}"
                width="600"
                height="600"
                loading="lazy"
                class="ai-recent-product-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-recent-product-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <h3 class="ai-recent-product-title-{{ ai_gen_id }}">{{ product.title }}</h3>

          <div class="ai-recent-product-price-{{ ai_gen_id }}">
            {{ product.price | money }}
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</recent-products-{{ ai_gen_id }}>

<script>
  (function() {
    class RecentProducts{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('recent-products-{{ ai_gen_id }}', RecentProducts{{ ai_gen_id }});
  })();
</script>

