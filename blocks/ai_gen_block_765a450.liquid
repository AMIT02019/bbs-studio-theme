{% doc %}
  @prompt
    Create a luxury vintage banner section for a Shopify store with an artistic editorial aesthetic inspired by antique textiles, classical artwork, and high-end fashion campaigns.
    
    SECTION STYLE:
    - Cinematic luxury fashion aesthetic
    - Vintage editorial mood
    - Warm golden lighting
    - Artistic textile-inspired visuals
    - Sophisticated museum-like atmosphere
    - Minimal and premium presentation
    
    LAYOUT:
    - Full-width horizontal image banner
    - Edge-to-edge design
    - Large immersive visual section
    - Minimal content or optional overlay text
    - Elegant luxury spacing
    - Responsive across all devices
    
    IMAGE STYLE:
    - Close-up vintage textile artwork
    - Renaissance-inspired illustration details
    - Warm beige, gold, black, and sepia tones
    - Rich fabric texture
    - Soft cinematic shadows
    - Editorial fashion campaign look
    - Antique luxury atmosphere
    - High contrast artistic composition
    
    BACKGROUND SETTINGS:
    Add customizable image attachment options:
    - default
    - scroll
    - fixed
    
    Allow these options inside Shopify settings so the user can switch between:
    1. Default background behavior
    2. Scrolling background
    3. Fixed parallax-style background
    
    CSS REQUIREMENTS:
    - background-size: cover
    - background-position: center
    - background-repeat: no-repeat
    - smooth rendering
    - responsive image scaling
    
    PARALLAX EFFECT:
    When “fixed” is selected:
    - Create elegant parallax scrolling effect
    - Smooth luxury movement
    - Cinematic premium experience
    - Maintain performance optimization
    
    OPTIONAL CONTENT:
    Allow optional:
    - heading
    - subheading
    - button
    - overlay opacity controls
    
    TYPOGRAPHY:
    - Elegant serif or luxury sans-serif
    - White or soft beige text
    - Minimal editorial spacing
    - Sophisticated uppercase style
    
    SPACING:
    - Large vertical spacing
    - Full-width immersive section
    - Minimal distractions
    - Luxury fashion editorial proportions
    
    MOBILE OPTIMIZATION:
    - Disable aggressive fixed background on mobile if needed
    - Maintain image quality
    - Preserve luxury composition
    - Responsive height adjustments
    
    SHOPIFY REQUIREMENTS:
    - Build as editable Shopify section
    - Editable background image
    - Adjustable section height
    - Background attachment selector:
      - default
      - scroll
      - fixed
    - Adjustable overlay darkness
    - Responsive controls
    - Optimized for Dawn theme
    
    ADVANCED FEATURES:
    - Smooth fade-in animation
    - Optional zoom/parallax effect
    - Lazy-loaded image
    - High-performance rendering
    - Elegant cinematic transitions
    
    OVERALL GOAL:
    The section should feel like a luxury fashion editorial banner inspired by vintage art, museum textiles, and premium antique storytelling — immersive, cinematic, artistic, and highly sophisticated.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-luxury-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-luxury-banner__background-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.section_height_desktop }}px;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    {% if block.settings.background_attachment == 'fixed' %}
      background-attachment: fixed;
    {% elsif block.settings.background_attachment == 'scroll' %}
      background-attachment: scroll;
    {% else %}
      background-attachment: initial;
    {% endif %}
    {% if block.settings.banner_image %}
      background-image: url('{{ block.settings.banner_image | image_url: width: 2400 }}');
    {% endif %}
  }

  .ai-luxury-banner__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.section_height_desktop }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-luxury-banner__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 800px;
    max-height: 600px;
    opacity: 0.3;
  }

  .ai-luxury-banner__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    padding: 16px 32px;
    font-size: 16px;
    color: #666;
    text-align: center;
    pointer-events: none;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 4px;
  }

  .ai-luxury-banner__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, {{ block.settings.overlay_opacity }});
    z-index: 1;
  }

  .ai-luxury-banner__content-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    text-align: center;
    width: 90%;
    max-width: {{ block.settings.content_max_width }}px;
  }

  .ai-luxury-banner__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    text-transform: {{ block.settings.heading_transform }};
    letter-spacing: {{ block.settings.heading_letter_spacing }};
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px 0;
    line-height: 1.2;
  }

  .ai-luxury-banner__subheading-{{ ai_gen_id }} {
    color: {{ block.settings.subheading_color }};
    font-size: {{ block.settings.subheading_size }}px;
    font-weight: {{ block.settings.subheading_weight }};
    letter-spacing: {{ block.settings.subheading_letter_spacing }};
    margin: 0 0 {{ block.settings.subheading_margin_bottom }}px 0;
    line-height: 1.5;
  }

  .ai-luxury-banner__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-transform: {{ block.settings.button_text_transform }};
    letter-spacing: {{ block.settings.button_letter_spacing }};
    text-decoration: none;
    transition: all 0.3s ease;
    margin-top: {{ block.settings.button_margin_top }}px;
  }

  .ai-luxury-banner__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_bg_color_hover }};
    color: {{ block.settings.button_text_color_hover }};
    border-color: {{ block.settings.button_border_color_hover }};
  }

  @media screen and (max-width: 749px) {
    .ai-luxury-banner__background-{{ ai_gen_id }} {
      height: {{ block.settings.section_height_mobile }}px;
      {% if block.settings.disable_fixed_mobile %}
        background-attachment: scroll !important;
      {% endif %}
    }

    .ai-luxury-banner__placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.section_height_mobile }}px;
    }

    .ai-luxury-banner__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-luxury-banner__subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.8 }}px;
    }

    .ai-luxury-banner__button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
      padding: {{ block.settings.button_padding_vertical | times: 0.8 }}px {{ block.settings.button_padding_horizontal | times: 0.8 }}px;
    }
  }

  {% if block.settings.enable_fade_in %}
    @keyframes ai-luxury-fade-in-{{ ai_gen_id }} {
      from {
        opacity: 0;
        transform: translate(-50%, -45%);
      }
      to {
        opacity: 1;
        transform: translate(-50%, -50%);
      }
    }

    .ai-luxury-banner__content-{{ ai_gen_id }} {
      animation: ai-luxury-fade-in-{{ ai_gen_id }} 1s ease-out forwards;
    }
  {% endif %}
{% endstyle %}

<luxury-vintage-banner-{{ ai_gen_id }}
  class="ai-luxury-banner-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.banner_image %}
    <div class="ai-luxury-banner__background-{{ ai_gen_id }}">
      <div class="ai-luxury-banner__overlay-{{ ai_gen_id }}"></div>
      
      {% if block.settings.show_content %}
        <div class="ai-luxury-banner__content-{{ ai_gen_id }}">
          {% if block.settings.heading != blank %}
            <h2 class="ai-luxury-banner__heading-{{ ai_gen_id }}">
              {{ block.settings.heading }}
            </h2>
          {% endif %}

          {% if block.settings.subheading != blank %}
            <div class="ai-luxury-banner__subheading-{{ ai_gen_id }}">
              {{ block.settings.subheading }}
            </div>
          {% endif %}

          {% if block.settings.button_text != blank and block.settings.button_link != blank %}
            <a
              href="{{ block.settings.button_link }}"
              class="ai-luxury-banner__button-{{ ai_gen_id }}"
            >
              {{ block.settings.button_text }}
            </a>
          {% endif %}
        </div>
      {% endif %}
    </div>
  {% else %}
    <div class="ai-luxury-banner__placeholder-{{ ai_gen_id }}">
      {{ 'hero-apparel-1' | placeholder_svg_tag }}
      <div class="ai-luxury-banner__empty-state-{{ ai_gen_id }}">
        Add a luxury vintage image to begin
      </div>
    </div>
  {% endif %}
</luxury-vintage-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class LuxuryVintageBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.init();
      }

      init() {
        const background = this.querySelector('.ai-luxury-banner__background-{{ ai_gen_id }}');
        if (!background) return;

        if (window.IntersectionObserver) {
          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  background.style.opacity = '1';
                }
              });
            },
            { threshold: 0.1 }
          );

          observer.observe(background);
        }
      }
    }

    customElements.define('luxury-vintage-banner-{{ ai_gen_id }}', LuxuryVintageBanner{{ ai_gen_id }});
  })();
</script>

