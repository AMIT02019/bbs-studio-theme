{% doc %}
  @prompt
    <div class="bulk-sales-container">
      <h1>Bulk Sales Inquiry</h1>
    
      {% form 'contact' %}
        
        {% if form.posted_successfully? %}
          <p class="success-message">
            Thank you. Our supplier will contact you shortly regarding your bulk order.
          </p>
        {% endif %}
    
        {{ form.errors | default_errors }}
    
        <label>Full Name *</label>
        <input type="text" name="contact[name]" required>
    
        <label>Company Name</label>
        <input type="text" name="contact[Company]">
    
        <label>Email Address *</label>
        <input type="email" name="contact[email]" required>
    
        <label>Phone Number *</label>
        <input type="tel" name="contact[Phone]" required>
    
        <label>Book Title *</label>
        <select name="contact[Book Title]" required>
          <option value="">Select a Book</option>
          {% assign books = collections['books'] %}
          {% for product in books.products %}
            {% if product.available %}
              <option value="{{ product.title }}">
                {{ product.title }}
              </option>
            {% endif %}
          {% endfor %}
        </select>
    
        <label>Quantity *</label>
        <input type="number" name="contact[Quantity]" min="1" required>
    
        <label>Additional Notes</label>
        <textarea name="contact[Notes]"></textarea>
    
        <button type="submit">Submit Bulk Request</button>
    
      {% endform %}
    </div>
    
    <style>
    .bulk-sales-container {
      max-width: 600px;
      margin: 40px auto;
      padding: 20px;
    }
    
    .bulk-sales-container input,
    .bulk-sales-container select,
    .bulk-sales-container textarea {
      width: 100%;
      padding: 10px;
      margin-bottom: 15px;
    }
    
    .bulk-sales-container button {
      background: #000;
      color: #fff;
      padding: 12px;
      border: none;
      cursor: pointer;
      width: 100%;
    }
    
    .success-message {
      color: green;
      font-weight: bold;
      margin-bottom: 20px;
    }
    </style>
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-bulk-sales-container-{{ ai_gen_id }} {
    display: block;
    max-width: {{ block.settings.max_width }}px;
    margin: {{ block.settings.margin_top }}px auto {{ block.settings.margin_bottom }}px;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    width: {{ block.settings.desktop_width_percent }}%;
  }

  .ai-bulk-sales-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px;
    text-align: {{ block.settings.text_align }};
  }

  .ai-bulk-sales-form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.field_spacing }}px;
  }

  .ai-bulk-sales-label-{{ ai_gen_id }} {
    display: block;
    margin-bottom: 8px;
    color: {{ block.settings.label_color }};
    font-size: {{ block.settings.label_size }}px;
    font-weight: {{ block.settings.label_weight }};
  }

  .ai-bulk-sales-input-{{ ai_gen_id }},
  .ai-bulk-sales-select-{{ ai_gen_id }},
  .ai-bulk-sales-textarea-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.input_padding }}px;
    border: {{ block.settings.input_border_width }}px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: {{ block.settings.input_font_size }}px;
    color: {{ block.settings.input_text_color }};
    background-color: {{ block.settings.input_background_color }};
  }

  .ai-bulk-sales-input-{{ ai_gen_id }}:focus,
  .ai-bulk-sales-select-{{ ai_gen_id }}:focus,
  .ai-bulk-sales-textarea-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.input_focus_color }};
    outline-offset: 2px;
  }

  .ai-bulk-sales-textarea-{{ ai_gen_id }} {
    min-height: 100px;
    resize: vertical;
  }

  .ai-bulk-sales-button-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-bulk-sales-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-bulk-sales-success-{{ ai_gen_id }} {
    color: {{ block.settings.success_color }};
    font-weight: 600;
    margin-bottom: 20px;
    padding: 12px;
    background-color: {{ block.settings.success_background }};
    border-radius: {{ block.settings.input_border_radius }}px;
  }

  .ai-bulk-sales-error-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
    margin-bottom: 20px;
    padding: 12px;
    background-color: {{ block.settings.error_background }};
    border-radius: {{ block.settings.input_border_radius }}px;
  }

  .ai-bulk-sales-required-{{ ai_gen_id }} {
    color: {{ block.settings.required_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-bulk-sales-container-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.padding | times: 0.7 }}px;
    }
  }
{% endstyle %}

<div class="ai-bulk-sales-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="ai-bulk-sales-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  {% form 'contact' %}
    {% if form.posted_successfully? %}
      <div class="ai-bulk-sales-success-{{ ai_gen_id }}">
        {{ block.settings.success_message }}
      </div>
    {% endif %}

    {% if form.errors %}
      <div class="ai-bulk-sales-error-{{ ai_gen_id }}">
        {{ form.errors | default_errors }}
      </div>
    {% endif %}

    <div class="ai-bulk-sales-form-{{ ai_gen_id }}">
      <div>
        <label class="ai-bulk-sales-label-{{ ai_gen_id }}">
          {{ block.settings.name_label }} <span class="ai-bulk-sales-required-{{ ai_gen_id }}">*</span>
        </label>
        <input
          type="text"
          name="contact[name]"
          class="ai-bulk-sales-input-{{ ai_gen_id }}"
          required
          aria-required="true"
        >
      </div>

      <div>
        <label class="ai-bulk-sales-label-{{ ai_gen_id }}">
          {{ block.settings.company_label }}
        </label>
        <input
          type="text"
          name="contact[Company]"
          class="ai-bulk-sales-input-{{ ai_gen_id }}"
        >
      </div>

      <div>
        <label class="ai-bulk-sales-label-{{ ai_gen_id }}">
          {{ block.settings.email_label }} <span class="ai-bulk-sales-required-{{ ai_gen_id }}">*</span>
        </label>
        <input
          type="email"
          name="contact[email]"
          class="ai-bulk-sales-input-{{ ai_gen_id }}"
          required
          aria-required="true"
        >
      </div>

      <div>
        <label class="ai-bulk-sales-label-{{ ai_gen_id }}">
          {{ block.settings.phone_label }} <span class="ai-bulk-sales-required-{{ ai_gen_id }}">*</span>
        </label>
        <input
          type="tel"
          name="contact[Phone]"
          class="ai-bulk-sales-input-{{ ai_gen_id }}"
          required
          aria-required="true"
        >
      </div>

      <div>
        <label class="ai-bulk-sales-label-{{ ai_gen_id }}">
          {{ block.settings.book_label }} <span class="ai-bulk-sales-required-{{ ai_gen_id }}">*</span>
        </label>
        <select
          name="contact[Book Title]"
          class="ai-bulk-sales-select-{{ ai_gen_id }}"
          required
          aria-required="true"
        >
          <option value="">{{ block.settings.book_placeholder }}</option>
          {% if block.settings.books_collection != blank %}
            {% assign books = collections[block.settings.books_collection.handle] %}
            {% for product in books.products %}
              {% if product.available %}
                <option value="{{ product.title }}">{{ product.title }}</option>
              {% endif %}
            {% endfor %}
          {% endif %}
        </select>
      </div>

      <div>
        <label class="ai-bulk-sales-label-{{ ai_gen_id }}">
          {{ block.settings.quantity_label }} <span class="ai-bulk-sales-required-{{ ai_gen_id }}">*</span>
        </label>
        <input
          type="number"
          name="contact[Quantity]"
          min="1"
          class="ai-bulk-sales-input-{{ ai_gen_id }}"
          required
          aria-required="true"
        >
      </div>

      <div>
        <label class="ai-bulk-sales-label-{{ ai_gen_id }}">
          {{ block.settings.notes_label }}
        </label>
        <textarea
          name="contact[Notes]"
          class="ai-bulk-sales-textarea-{{ ai_gen_id }}"
        ></textarea>
      </div>

      <button type="submit" class="ai-bulk-sales-button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </button>
    </div>
  {% endform %}
</div>

