{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-recent-purchased-{{ ai_gen_id }} {
    display: block;
    background: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
    overflow: hidden;
    width: 100%;
  }

  .ai-recent-purchased-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-recent-purchased-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_margin_bottom }}px;
  }

  .ai-recent-purchased-heading-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.1;
    letter-spacing: {{ block.settings.heading_letter_spacing }};
    text-transform: {{ block.settings.heading_text_transform }};
    font-weight: {{ block.settings.heading_font_weight }};
    color: {{ block.settings.heading_color }};
  }

  .ai-recent-purchased-subtitle-{{ ai_gen_id }} {
    margin-top: 16px;
    color: {{ block.settings.subtitle_color }};
    font-size: {{ block.settings.subtitle_size }}px;
    letter-spacing: 0.06em;
  }

  .ai-recent-purchased-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-rp-card-{{ ai_gen_id }} {
    background: {{ block.settings.card_background }};
    border: 1px solid {{ block.settings.card_border_color }};
    transition: all 0.45s ease;
    height: 100%;
  }

  .ai-rp-card-{{ ai_gen_id }}:hover {
    box-shadow: {{ block.settings.card_hover_shadow }};
    transform: translateY(-4px);
  }

  .ai-rp-card-link-{{ ai_gen_id }} {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .ai-rp-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    background: #fafafa;
    aspect-ratio: 1 / 1;
  }

  .ai-rp-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.8s ease, opacity 0.5s ease;
  }

  .ai-rp-card-{{ ai_gen_id }}:hover .ai-rp-primary-image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-rp-hover-image-{{ ai_gen_id }} {
    position: absolute;
    inset: 0;
    opacity: 0;
  }

  .ai-rp-card-{{ ai_gen_id }}:hover .ai-rp-hover-image-{{ ai_gen_id }} {
    opacity: 1;
    transform: scale(1.05);
  }

  .ai-rp-content-{{ ai_gen_id }} {
    padding: 28px 24px 34px;
    text-align: center;
  }

  .ai-rp-title-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.product_title_size }}px;
    line-height: 1.5;
    color: {{ block.settings.product_title_color }};
    font-weight: {{ block.settings.product_title_font_weight }};
    letter-spacing: 0.02em;
  }

  .ai-rp-price-{{ ai_gen_id }} {
    margin-top: 10px;
    font-size: {{ block.settings.product_price_size }}px;
    color: {{ block.settings.product_price_color }};
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  .ai-rp-button-wrapper-{{ ai_gen_id }} {
    text-align: center;
    margin-top: {{ block.settings.button_margin_top }}px;
  }

  .ai-rp-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    text-transform: {{ block.settings.button_text_transform }};
    letter-spacing: {{ block.settings.button_letter_spacing }};
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    transition: all 0.35s ease;
  }

  .ai-rp-button-{{ ai_gen_id }}:hover {
    background: {{ block.settings.button_hover_background }};
    transform: translateY(-2px);
  }

  .ai-rp-button-arrow-{{ ai_gen_id }} {
    transition: transform 0.3s ease;
  }

  .ai-rp-button-{{ ai_gen_id }}:hover .ai-rp-button-arrow-{{ ai_gen_id }} {
    transform: translateX(3px);
  }

  .ai-rp-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #999;
    font-size: 14px;
  }

  @media screen and (max-width: 989px) {
    .ai-recent-purchased-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
      gap: 28px;
    }

    .ai-recent-purchased-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-recent-purchased-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.8 }}px 0 {{ block.settings.padding_bottom | times: 0.8 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-recent-purchased-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: 24px;
    }

    .ai-recent-purchased-header-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.header_margin_bottom | times: 0.7 }}px;
    }

    .ai-recent-purchased-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
    }
  }
{% endstyle %}

<ai-recent-purchased-{{ ai_gen_id }}
  class="ai-recent-purchased-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-recent-purchased-container-{{ ai_gen_id }}">
    <div class="ai-recent-purchased-header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-recent-purchased-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.subtitle != blank %}
        <p class="ai-recent-purchased-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
      {% endif %}
    </div>

    {% if block.settings.product_1 != blank or block.settings.product_2 != blank or block.settings.product_3 != blank %}
      <div class="ai-recent-purchased-grid-{{ ai_gen_id }}">
        {% for i in (1..3) %}
          {% assign product_key = 'product_' | append: i %}
          {% assign product = block.settings[product_key] %}

          {% if product != blank %}
            <article class="ai-rp-card-{{ ai_gen_id }}">
              <a href="{{ product.url }}" class="ai-rp-card-link-{{ ai_gen_id }}">
                <div class="ai-rp-image-wrapper-{{ ai_gen_id }}">
                  {% if product.featured_image %}
                    <img
                      class="ai-rp-image-{{ ai_gen_id }} ai-rp-primary-image-{{ ai_gen_id }}"
                      src="{{ product.featured_image | image_url: width: 1200 }}"
                      alt="{{ product.title | escape }}"
                      loading="lazy"
                      width="{{ product.featured_image.width }}"
                      height="{{ product.featured_image.height }}"
                    >
                  {% endif %}

                  {% if block.settings.enable_hover_image and product.images.size > 1 %}
                    <img
                      class="ai-rp-image-{{ ai_gen_id }} ai-rp-hover-image-{{ ai_gen_id }}"
                      src="{{ product.images[1] | image_url: width: 1200 }}"
                      alt="{{ product.title | escape }}"
                      loading="lazy"
                      width="{{ product.images[1].width }}"
                      height="{{ product.images[1].height }}"
                    >
                  {% endif %}
                </div>

                <div class="ai-rp-content-{{ ai_gen_id }}">
                  <h3 class="ai-rp-title-{{ ai_gen_id }}">{{ product.title }}</h3>
                  <div class="ai-rp-price-{{ ai_gen_id }}">
                    {{ product.price | money }}
                  </div>
                </div>
              </a>
            </article>
          {% endif %}
        {% endfor %}
      </div>

      {% if block.settings.button_link != blank and block.settings.button_text != blank %}
        <div class="ai-rp-button-wrapper-{{ ai_gen_id }}">
          <a href="{{ block.settings.button_link }}" class="ai-rp-button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
            <span class="ai-rp-button-arrow-{{ ai_gen_id }}">→</span>
          </a>
        </div>
      {% endif %}
    {% else %}
      <div class="ai-rp-empty-state-{{ ai_gen_id }}">
        Next, add products to display
      </div>
    {% endif %}
  </div>
</ai-recent-purchased-{{ ai_gen_id }}>

