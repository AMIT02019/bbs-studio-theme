{% doc %}
  @prompt
    <section
      id="recent-purchased-{{ section.id }}"
      class="recent-purchased-section"
    >
      <div class="page-width">
    
        <div class="recent-purchased-header reveal">
          <h2>{{ section.settings.heading }}</h2>
          <p>{{ section.settings.subtitle }}</p>
        </div>
    
        <div class="recent-purchased-grid">
    
          {% for block in section.blocks %}
            {% assign product = block.settings.product %}
    
            {% if product %}
              <article
                class="rp-card reveal"
                {{ block.shopify_attributes }}
              >
    
                <a href="{{ product.url }}" class="rp-card-link">
    
                  <div class="rp-image-wrapper">
    
                    {% if product.featured_image %}
                      <img
                        class="rp-image primary-image"
                        src="{{ product.featured_image | image_url: width: 1200 }}"
                        alt="{{ product.title }}"
                        loading="lazy"
                        width=""
                        height=""
                      >
                    {% endif %}
    
                    {% if section.settings.enable_hover_image and product.images.size > 1 %}
                      <img
                        class="rp-image hover-image"
                        src="{{ product.images[1] | image_url: width: 1200 }}"
                        alt="{{ product.title }}"
                        loading="lazy"
                        width=""
                        height=""
                      >
                    {% endif %}
    
                  </div>
    
                  <div class="rp-content">
                    <h3>{{ product.title }}</h3>
    
                    <div class="rp-price">
                      {{ product.price | money }}
                    </div>
                  </div>
    
                </a>
    
              </article>
            {% endif %}
          {% endfor %}
    
        </div>
    
        {% if section.settings.button_link != blank %}
          <div class="rp-button-wrapper reveal">
            <a
              href="{{ section.settings.button_link }}"
              class="rp-button"
            >
              {{ section.settings.button_text }}
              <span>→</span>
            </a>
          </div>
        {% endif %}
    
      </div>
    </section>
    
    <style>
    #recent-purchased-{{ section.id }}{
      background: #f8f6f3;
      padding: 110px 0;
      overflow: hidden;
    }
    
    #recent-purchased-{{ section.id }} .page-width{
      max-width: 1400px;
      margin: 0 auto;
    }
    
    .recent-purchased-header{
      text-align:center;
      margin-bottom:70px;
    }
    
    .recent-purchased-header h2{
      margin:0;
      font-size:48px;
      line-height:1.1;
      letter-spacing:0.18em;
      text-transform:uppercase;
      font-weight:700;
      color:#222;
    }
    
    .recent-purchased-header p{
      margin-top:16px;
      color:#8c8c8c;
      font-size:14px;
      letter-spacing:0.06em;
    }
    
    .recent-purchased-grid{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:40px;
    }
    
    .rp-card{
      background:#fff;
      border:1px solid rgba(0,0,0,.08);
      transition:all .45s ease;
      height:100%;
    }
    
    .rp-card:hover{
      box-shadow:0 20px 50px rgba(0,0,0,.08);
      transform:translateY(-4px);
    }
    
    .rp-card-link{
      text-decoration:none;
      color:inherit;
      display:flex;
      flex-direction:column;
      height:100%;
    }
    
    .rp-image-wrapper{
      position:relative;
      overflow:hidden;
      background:#fafafa;
      aspect-ratio:1/1;
    }
    
    .rp-image{
      width:100%;
      height:100%;
      object-fit:cover;
      display:block;
      transition:transform .8s ease, opacity .5s ease;
    }
    
    .rp-card:hover .primary-image{
      transform:scale(1.05);
    }
    
    .hover-image{
      position:absolute;
      inset:0;
      opacity:0;
    }
    
    .rp-card:hover .hover-image{
      opacity:1;
      transform:scale(1.05);
    }
    
    .rp-content{
      padding:28px 24px 34px;
      text-align:center;
    }
    
    .rp-content h3{
      margin:0;
      font-size:18px;
      line-height:1.5;
      color:#222;
      font-weight:500;
      letter-spacing:.02em;
    }
    
    .rp-price{
      margin-top:10px;
      font-size:15px;
      color:#a38b63;
      font-weight:500;
      letter-spacing:.04em;
    }
    
    .rp-button-wrapper{
      text-align:center;
      margin-top:70px;
    }
    
    .rp-button{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:10px;
      padding:16px 34px;
      background:#222;
      color:#fff;
      text-decoration:none;
      text-transform:uppercase;
      letter-spacing:.15em;
      font-size:13px;
      font-weight:600;
      transition:all .35s ease;
    }
    
    .rp-button:hover{
      background:#383838;
      transform:translateY(-2px);
    }
    
    .rp-button span{
      transition:transform .3s ease;
    }
    
    .rp-button:hover span{
      transform:translateX(3px);
    }
    
    .reveal{
      opacity:0;
      transform:translateY(35px);
      transition:
        opacity .8s ease,
        transform .8s ease;
    }
    
    .reveal.visible{
      opacity:1;
      transform:translateY(0);
    }
    
    @media screen and (max-width: 989px){
    
      .recent-purchased-grid{
        grid-template-columns:repeat(2,1fr);
        gap:28px;
      }
    
      .recent-purchased-header h2{
        font-size:38px;
      }
    
      #recent-purchased-{{ section.id }}{
        padding:90px 0;
      }
    }
    
