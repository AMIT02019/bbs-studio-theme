{% doc %}
  @prompt
    {% if collection.handle == 'coming-soon' %}
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600&family=Poppins:wght@300;400;500&display=swap" rel="stylesheet">
    
    <style>
    
    .cs-luxury{
        min-height:100vh;
        background:#f5f1ea;
        display:grid;
        grid-template-columns:1fr 1fr;
    }
    
    .cs-content{
        padding:70px;
        display:flex;
        flex-direction:column;
        justify-content:center;
        position:relative;
    }
    
    .cs-logo{
        font-size:18px;
        letter-spacing:2px;
        margin-bottom:40px;
    }
    
    .cs-title{
        font-family:'Cormorant Garamond', serif;
        font-size:120px;
        line-height:.9;
        font-weight:400;
        color:#a45318;
        margin:0;
    }
    
    .cs-subtitle{
        margin-top:40px;
        font-size:20px;
        max-width:500px;
        line-height:1.8;
        color:#444;
        font-family:'Poppins',sans-serif;
    }
    
    .cs-line{
        width:200px;
        height:1px;
        background:#a45318;
        margin:40px 0;
    }
    
    .cs-badge{
        display:inline-block;
        background:#111;
        color:#fff;
        padding:10px 20px;
        font-size:14px;
        margin-top:25px;
    }
    
    .cs-image{
        position:relative;
        overflow:hidden;
    }
    
    .cs-image img{
        width:100%;
        height:100%;
        object-fit:cover;
    }
    
    .cs-vertical{
        position:absolute;
        right:25px;
        top:50%;
        transform:translateY(-50%) rotate(180deg);
        writing-mode:vertical-lr;
        letter-spacing:8px;
        font-size:22px;
        color:#222;
        font-family:'Cormorant Garamond', serif;
    }
    
    .cs-stars{
        position:absolute;
        top:30px;
        left:30px;
        color:#a45318;
        font-size:24px;
    }
    
    @media(max-width:990px){
    
    .cs-luxury{
        grid-template-columns:1fr;
    }
    
    .cs-content{
        padding:40px 25px;
    }
    
    .cs-title{
        font-size:80px;
    }
    
    .cs-image{
        height:500px;
    }
    
    .cs-vertical{
        display:none;
    }
    }
    
    </style>
    
    <div class="cs-luxury">
    
        <div class="cs-content">
    
            <div class="cs-stars">✦</div>
    
            <div class="cs-logo">
                {{ shop.name }}
            </div>
    
            <h1 class="cs-title">
                Coming<br>Soon
            </h1>
    
            <div class="cs-badge">
                A New Era of Luxury
            </div>
    
            <div class="cs-line"></div>
    
            <p class="cs-subtitle">
                Discover timeless pieces designed with refined craftsmanship,
                modern beauty and effortless sophistication.
                Our newest collection will be launching soon.
            </p>
    
        </div>
    
        <div class="cs-image">
    
            <!-- Replace image URL below -->
            <img src="https://images.unsplash.com/photo-1617038260897-41a1f14a8ca6?q=80&w=1600" alt="Coming Soon">
    
            <div class="cs-vertical">
                LAUNCHING SOON
            </div>
    
        </div>
    
    </div>
    
    {% else %}
      {% comment %} Normal Collection Content {% endcomment %}
    {% endif %}
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-coming-soon-{{ ai_gen_id }} {
    display: block;
    min-height: 100vh;
    background-color: {{ block.settings.background_color }};
    width: 100%;
  }

  .ai-coming-soon-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 100vh;
  }

  .ai-coming-soon-content-{{ ai_gen_id }} {
    padding: 70px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
  }

  .ai-coming-soon-logo-{{ ai_gen_id }} {
    font-size: {{ block.settings.logo_font_size }}px;
    letter-spacing: 2px;
    margin-bottom: 40px;
    color: {{ block.settings.text_color }};
  }

  .ai-coming-soon-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    line-height: 0.9;
    font-weight: {{ block.settings.title_font_weight }};
    color: {{ block.settings.title_color }};
    margin: 0;
  }

  .ai-coming-soon-subtitle-{{ ai_gen_id }} {
    margin-top: 40px;
    font-size: {{ block.settings.subtitle_font_size }}px;
    max-width: 500px;
    line-height: 1.8;
    color: {{ block.settings.text_color }};
  }

  .ai-coming-soon-line-{{ ai_gen_id }} {
    width: {{ block.settings.line_width }}px;
    height: 1px;
    background-color: {{ block.settings.line_color }};
    margin: 40px 0;
  }

  .ai-coming-soon-badge-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    padding: 10px 20px;
    font-size: {{ block.settings.badge_font_size }}px;
    margin-top: 25px;
  }

  .ai-coming-soon-image-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-coming-soon-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-coming-soon-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-coming-soon-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-coming-soon-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-coming-soon-vertical-{{ ai_gen_id }} {
    position: absolute;
    right: 25px;
    top: 50%;
    transform: translateY(-50%) rotate(180deg);
    writing-mode: vertical-lr;
    letter-spacing: 8px;
    font-size: {{ block.settings.vertical_text_font_size }}px;
    color: {{ block.settings.vertical_text_color }};
  }

  .ai-coming-soon-stars-{{ ai_gen_id }} {
    position: absolute;
    top: 30px;
    left: 30px;
    color: {{ block.settings.star_color }};
    font-size: {{ block.settings.star_size }}px;
  }

  @media (max-width: 990px) {
    .ai-coming-soon-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-coming-soon-content-{{ ai_gen_id }} {
      padding: 40px 25px;
    }

    .ai-coming-soon-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size | times: 0.67 }}px;
    }

    .ai-coming-soon-image-{{ ai_gen_id }} {
      height: 500px;
    }

    .ai-coming-soon-vertical-{{ ai_gen_id }} {
      display: none;
    }
  }
{% endstyle %}

<coming-soon-{{ ai_gen_id }} class="ai-coming-soon-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-coming-soon-container-{{ ai_gen_id }}">
    <div class="ai-coming-soon-content-{{ ai_gen_id }}">
      {% if block.settings.show_star %}
        <div class="ai-coming-soon-stars-{{ ai_gen_id }}">{{ block.settings.star_symbol }}</div>
      {% endif %}

      {% if block.settings.show_logo %}
        <div class="ai-coming-soon-logo-{{ ai_gen_id }}">
          {{ shop.name }}
        </div>
      {% endif %}

      <h1 class="ai-coming-soon-title-{{ ai_gen_id }}">
        {{ block.settings.title }}
      </h1>

      {% if block.settings.badge_text != blank %}
        <div class="ai-coming-soon-badge-{{ ai_gen_id }}">
          {{ block.settings.badge_text }}
        </div>
      {% endif %}

      <div class="ai-coming-soon-line-{{ ai_gen_id }}"></div>

      {% if block.settings.subtitle != blank %}
        <div class="ai-coming-soon-subtitle-{{ ai_gen_id }}">
          {{ block.settings.subtitle }}
        </div>
      {% endif %}
    </div>

    <div class="ai-coming-soon-image-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 2000 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
        >
      {% else %}
        <div class="ai-coming-soon-image-placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-coming-soon-empty-state-{{ ai_gen_id }}">
            Next, add an image
          </div>
        </div>
      {% endif %}

      {% if block.settings.vertical_text != blank %}
        <div class="ai-coming-soon-vertical-{{ ai_gen_id }}">
          {{ block.settings.vertical_text }}
        </div>
      {% endif %}
    </div>
  </div>
</coming-soon-{{ ai_gen_id }}>

{% schema %}
{
  "name": "Coming soon luxury",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "checkbox",
      "id": "show_logo",
      "label": "Show shop name",
      "default": true
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title",
      "default": "<p>Coming Soon</p>"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "A New Era of Luxury"
    },
    {
      "type": "richtext",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "<p>Discover timeless pieces designed with refined craftsmanship, modern beauty and effortless sophistication. Our newest collection will be launching soon.</p>"
    },
    {
      "type": "text",
      "id": "vertical_text",
      "label": "Vertical text",
      "default": "LAUNCHING SOON"
    },
    {
      "type": "checkbox",
      "id": "show_star",
      "label": "Show star symbol",
      "default": true
    },
    {
      "type": "text",
      "id": "star_symbol",
      "label": "Star symbol",
      "default": "✦"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f5f1ea"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title",
      "default": "#a45318"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#444444"
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Line",
      "default": "#a45318"
    },
    {
      "type": "color",
      "id": "badge_bg_color",
      "label": "Badge background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "vertical_text_color",
      "label": "Vertical text",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star",
      "default": "#a45318"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "logo_font_size",
      "label": "Logo size",
      "min": 10,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Title size",
      "min": 40,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 120
    },
    {
      "type": "select",
      "id": "title_font_weight",
      "label": "Title weight",
      "options": [
        {
          "value": "300",
          "label": "Light"
        },
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "400"
    },
    {
      "type": "range",
      "id": "subtitle_font_size",
      "label": "Subtitle size",
      "min": 12,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "badge_font_size",
      "label": "Badge size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "vertical_text_font_size",
      "label": "Vertical text size",
      "min": 14,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 22
    },
    {
      "type": "range",
      "id": "star_size",
      "label": "Star size",
      "min": 16,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "line_width",
      "label": "Line width",
      "min": 50,
      "max": 400,
      "step": 10,
      "unit": "px",
      "default": 200
    }
  ],
  "presets": [
    {
      "name": "Coming soon luxury"
    }
  ]
}
{% endschema %}