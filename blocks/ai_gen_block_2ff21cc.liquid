{% doc %}
  @prompt
    Section Header
    
    Title: “BEST SELLER”
    
    Left-aligned
    
    Bold, uppercase
    
    Subtle divider line below
    
    Right side:
    
    “VIEW ALL” button
    
    Links automatically to selected collection page
    
    Blue accent color
    
    Clean, minimal button style
    
    Header layout:
    
    display: flex
    
    justify-content: space-between
    
    align-items: center
    
    Responsive stacking on mobile
    
    Collection Integration (Dynamic)
    
    Add a Collection Picker option
    
    Products must dynamically load from selected collection
    
    No manual product selection
    
    Add setting to control number of products displayed
    
    This layout should be reusable for:
    
    BEST SELLER
    
    NEW ARRIVAL
    
    TRENDING
    
    Any other collection-based section
    
    Layout
    
    Desktop:
    
    Horizontal carousel/grid
    
    5 product cards per row
    
    Left and right arrow navigation
    
    Tablet:
    
    2–3 cards per row
    
    Mobile:
    
    Swipeable layout
    
    1–2 cards per row
    
    Product Card Design
    
    White card
    
    Soft shadow
    
    Rounded corners
    
    Entire card clickable
    
    Hover effect: slight lift or shadow increase
    
    Consistent spacing and alignment
    
    Book Cover Image
    
    Centered inside card
    
    Proper aspect ratio
    
    Image container must have:
    
    position: relative
    
    Badge / Tag (Top Corner)
    
    Rectangle shape (NOT circular)
    
    Positioned at top-left of image
    
    Inside image container
    
    position: absolute
    
    top: 12px
    
    left: 12px
    
    Bold uppercase text
    
    Red background
    
    White text
    
    Padding: 6px 10px
    
    Small border-radius (4–6px)
    
    High z-index so it stays visible
    
    Add setting options:
    
    Toggle badge on/off
    
    Custom badge text field (e.g., “BEST SELLER”, “NEW”, etc.)
    
    Product Title (Optional)
    
    Below image:
    
    Blue link-style text
    
    Clean bookstore-style typography
    
    Add toggle setting:
    ✔ Show / Hide Product Title
    
    If disabled, title should not render in HTML.
    
    Pricing (Optional)
    
    Below title:
    
    Bold dark text
    
    Currency format (e.g., 495.00)
    
    Clean spacing
    
    Add toggle setting:
    ✔ Show / Hide Price
    
    If disabled, price should not render in HTML.
    
    Styling
    
    Clean, minimal bookstore UI
    
    White background
    
    Subtle gray separators
    
    Blue accent color for links and buttons
    
    Red highlight for badge
    
    Accessible font sizes and contrast
    
    Customization Settings Summary
    
    Include:
    
    Section title (editable text)
    
    Collection picker
    
    Product limit control
    
    Desktop column option (up to 5 columns)
    
    Toggle: Show badge
    
    Badge text field
    
    Toggle: Show product title
    
    Toggle: Show product price
    
    “View All” button label
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
 /* Header Layout */

.ai-collection-header-{{ ai_gen_id }} {
  display: flex;
  align-items: center;
  gap: 20px;
}

/* Make title and button fixed width */
.ai-collection-title-{{ ai_gen_id }} {
  white-space: nowrap;
}

.ai-collection-view-all-{{ ai_gen_id }} {
  white-space: nowrap;
}

/* Middle Triangle Separator */
.ai-collection-separator-{{ ai_gen_id }} {
  flex: 1;
  height: 10px;
  background-image: url('{{ "orange-triangle.svg" | asset_url }}');
  background-repeat: repeat-x;
  background-position: center;
  background-size: 16px 10px;
}

  .ai-collection-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-collection-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
    padding-bottom: 15px;
    border-bottom: {{ block.settings.divider_height }}px solid {{ block.settings.divider_color }};
  }

  .ai-collection-title-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: 700;
    text-transform: uppercase;
    color: {{ block.settings.title_color }};
    letter-spacing: 0.05em;
  }

  .ai-collection-view-all-{{ ai_gen_id }} {
    display: inline-block;
    padding: 10px 20px;
    background-color: transparent;
    color: {{ block.settings.button_color }};
    text-decoration: none;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    text-transform: uppercase;
    border: 2px solid {{ block.settings.button_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: all 0.3s ease;
  }

  .ai-collection-view-all-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
  }

  .ai-collection-carousel-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-collection-products-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.desktop_columns }}, 1fr);
    gap: {{ block.settings.product_gap }}px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
  }

  .ai-collection-products-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-product-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    overflow: hidden;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .ai-product-card-{{ ai_gen_id }}:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
    transform: translateY(-4px);
  }

  .ai-product-image-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-top: 140%;
    overflow: hidden;
    background-color: #f8f8f8;
  }

  .ai-product-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-badge-{{ ai_gen_id }} {
    position: absolute;
    top: 0px;
    left: 0px;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 4px 4px;
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: 700;
    text-transform: uppercase;
    border-radius: {{ block.settings.badge_border_radius }}px;
    z-index: 10;
  }

  .ai-product-info-{{ ai_gen_id }} {
    padding: 16px;
  }

  .ai-product-title-{{ ai_gen_id }} {
    margin: 0 0 8px;
    font-size: {{ block.settings.product_title_font_size }}px;
    font-weight: 400;
    color: {{ block.settings.product_title_color }};
    text-decoration: none;
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .ai-product-title-{{ ai_gen_id }}:hover {
    color: {{ block.settings.product_title_hover_color }};
  }

  .ai-product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_price_font_size }}px;
    font-weight: 700;
    color: {{ block.settings.product_price_color }};
  }

  .ai-carousel-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.arrow_background }};
    color: {{ block.settings.arrow_color }};
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  .ai-carousel-nav-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_hover_background }};
    transform: translateY(-50%) scale(1.1);
  }

  .ai-carousel-nav-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-carousel-nav-left-{{ ai_gen_id }} {
    left: -20px;
  }

  .ai-carousel-nav-right-{{ ai_gen_id }} {
    right: -20px;
  }

  .ai-carousel-nav-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  @media screen and (max-width: 989px) {
    .ai-collection-products-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.tablet_columns }}, 1fr);
    }

    .ai-carousel-nav-{{ ai_gen_id }} {
      display: none;
    }
  }

  @media screen and (max-width: 749px) {
     .ai-product-badge-{{ ai_gen_id }} {
    top: 0px;
    left: 0px;
    padding: 2px 2px;
    font-size: 9px;
    border-radius: 3px;
  }


    .ai-collection-products-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.mobile_columns }}, 1fr);
      overflow-x: scroll;
      scroll-snap-type: x mandatory;
    }

    .ai-product-card-{{ ai_gen_id }} {
      scroll-snap-align: start;
    }

    .ai-collection-header-center-{{ ai_gen_id }} {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
}

.ai-collection-header-image-{{ ai_gen_id }} {
  max-height: {{ section.settings.header_image_height }}px;
  width: auto;
  object-fit: contain;
}

@media screen and (max-width: 749px) {
  .ai-collection-header-{{ ai_gen_id }} {
    flex-wrap: wrap;
  }

  .ai-collection-header-center-{{ ai_gen_id }} {
    order: 3;
    width: 100%;
    justify-content: center;
    margin-top: 10px;
  }
}

{% endstyle %}

<collection-carousel-{{ ai_gen_id }} class="ai-collection-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-collection-header-{{ ai_gen_id }}">
  
  <h2 class="ai-collection-title-{{ ai_gen_id }}">
    {{ block.settings.section_title }}
  </h2>

  <div class="ai-collection-separator-{{ ai_gen_id }}"></div>

  {% if block.settings.collection != blank %}
    <a href="{{ block.settings.collection.url }}" class="ai-collection-view-all-{{ ai_gen_id }}">
      {{ block.settings.view_all_text }}
    </a>
  {% endif %}

</div>


  <div class="ai-collection-carousel-{{ ai_gen_id }}">
    {% if block.settings.collection != blank %}
      <button class="ai-carousel-nav-{{ ai_gen_id }} ai-carousel-nav-left-{{ ai_gen_id }}" aria-label="Previous products">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <div class="ai-collection-products-{{ ai_gen_id }}">
        {% for product in block.settings.collection.products limit: block.settings.product_limit %}
          <div class="ai-product-card-{{ ai_gen_id }}" data-product-id="{{ product.id }}">
            <a href="{{ product.url }}" class="ai-product-link-{{ ai_gen_id }}">
              <div class="ai-product-image-container-{{ ai_gen_id }}">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    class="ai-product-image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="600"
                    height="840"
                  >
                {% else %}
                  <div class="ai-product-image-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}

                {% if block.settings.show_badge and block.settings.badge_text != blank %}
                  <div class="ai-product-badge-{{ ai_gen_id }}">{{ block.settings.badge_text }}</div>
                {% endif %}
              </div>

              <div class="ai-product-info-{{ ai_gen_id }}">
                {% if block.settings.show_product_title %}
                  <h3 class="ai-product-title-{{ ai_gen_id }}">{{ product.title }}</h3>
                {% endif %}

                {% if block.settings.show_price %}
                  <div class="ai-product-price-{{ ai_gen_id }}">
                    {{ product.price | money }}
                  </div>
                {% endif %}
              </div>
            </a>
          </div>
        {% endfor %}
      </div>

      <button class="ai-carousel-nav-{{ ai_gen_id }} ai-carousel-nav-right-{{ ai_gen_id }}" aria-label="Next products">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    {% else %}
      <div style="text-align: center; padding: 40px; color: #999; font-style: italic;">
        Select a collection to display products
      </div>
    {% endif %}
  </div>
</collection-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class CollectionCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.carousel = this.querySelector('.ai-collection-products-{{ ai_gen_id }}');
        this.leftButton = this.querySelector('.ai-carousel-nav-left-{{ ai_gen_id }}');
        this.rightButton = this.querySelector('.ai-carousel-nav-right-{{ ai_gen_id }}');

        if (!this.carousel) return;

        this.setupNavigation();
        this.updateButtonStates();
      }

      setupNavigation() {
        if (this.leftButton) {
          this.leftButton.addEventListener('click', () => this.scroll('left'));
        }

        if (this.rightButton) {
          this.rightButton.addEventListener('click', () => this.scroll('right'));
        }

        this.carousel.addEventListener('scroll', () => this.updateButtonStates());
      }

      scroll(direction) {
        const scrollAmount = this.carousel.offsetWidth * 0.8;
        const currentScroll = this.carousel.scrollLeft;

        if (direction === 'left') {
          this.carousel.scrollTo({
            left: currentScroll - scrollAmount,
            behavior: 'smooth'
          });
        } else {
          this.carousel.scrollTo({
            left: currentScroll + scrollAmount,
            behavior: 'smooth'
          });
        }
      }

      updateButtonStates() {
        if (!this.leftButton || !this.rightButton) return;

        const isAtStart = this.carousel.scrollLeft <= 0;
        const isAtEnd = this.carousel.scrollLeft + this.carousel.offsetWidth >= this.carousel.scrollWidth - 1;

        this.leftButton.disabled = isAtStart;
        this.rightButton.disabled = isAtEnd;
      }
    }

    customElements.define('collection-carousel-{{ ai_gen_id }}', CollectionCarousel{{ ai_gen_id }});
  })();
</script>

