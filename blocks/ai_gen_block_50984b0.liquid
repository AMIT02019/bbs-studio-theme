{% doc %}
  @prompt
    <div class="bulk-sales-container form-align-{{ section.settings.form_alignment }}">
      
      <h1 class="heading-align-{{ section.settings.heading_alignment }}">
        Bulk Sales Inquiry
      </h1>
    
      {% form 'contact' %}
        
        {% if form.posted_successfully? %}
          <p class="success-message">
            Thank you. Our supplier will contact you shortly regarding your bulk order.
          </p>
        {% endif %}
    
        {{ form.errors | default_errors }}
    
        <!-- Full Name (Text Only) -->
        <label>Full Name *</label>
        <input 
          type="text" 
          name="contact[name]" 
          required
          pattern="[A-Za-z\s]+"
          title="Name should contain letters only"
        >
    
        <!-- Company Name (Text Only) -->
        <label>Company Name</label>
        <input 
          type="text" 
          name="contact[Company]"
          pattern="[A-Za-z\s&]+"
          title="Company name should contain letters only"
        >
    
        <!-- Email -->
        <label>Email Address *</label>
        <input type="email" name="contact[email]" required>
    
        <!-- Phone (Numbers Only 10–15 digits) -->
        <label>Phone Number *</label>
        <input 
          type="tel" 
          name="contact[Phone]" 
          required
          pattern="[0-9]{10,15}"
          title="Please enter a valid phone number (10-15 digits only)"
        >
    
        {% capture all_books_options %}
          {% paginate collections['books'].products by 250 %}
            {% for product in collections['books'].products %}
              {% if product.available %}
                <option value="{{ product.title }}">
                  {{ product.title }}
                </option>
              {% endif %}
            {% endfor %}
          {% endpaginate %}
        {% endcapture %}
    
        <!-- Book Selection -->
        <label>Book Title *</label>
        <select name="contact[Book Title]" required>
          <option value="">Select a Book</option>
          {{ all_books_options }}
        </select>
    
        <!-- Quantity (Numbers Only) -->
        <label>Quantity *</label>
        <input 
          type="number" 
          name="contact[Quantity]" 
          min="1" 
          required
        >
    
        <!-- Notes (Letters + Numbers Only) -->
        <label>Additional Notes</label>
        <textarea 
          name="contact[Notes]"
          pattern="[A-Za-z0-9\s.,-]+"
          title="Only letters, numbers, comma, dot and dash allowed"
        ></textarea>
    
        <button type="submit">Submit Bulk Request</button>
    
      {% endform %}
    </div>
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-bulk-sales-form-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.form_padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-bulk-sales-form__heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    text-align: {{ block.settings.heading_alignment }};
  }

  .ai-bulk-sales-form__form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.field_spacing }}px;
  }

  .ai-bulk-sales-form__field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-bulk-sales-form__label-{{ ai_gen_id }} {
    color: {{ block.settings.label_color }};
    font-size: {{ block.settings.label_size }}px;
    font-weight: 500;
  }

  .ai-bulk-sales-form__input-{{ ai_gen_id }},
  .ai-bulk-sales-form__select-{{ ai_gen_id }},
  .ai-bulk-sales-form__textarea-{{ ai_gen_id }} {
    padding: 12px 16px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: {{ block.settings.input_text_size }}px;
    color: {{ block.settings.input_text_color }};
    background-color: {{ block.settings.input_background_color }};
    width: 100%;
  }

  .ai-bulk-sales-form__input-{{ ai_gen_id }}:focus,
  .ai-bulk-sales-form__select-{{ ai_gen_id }}:focus,
  .ai-bulk-sales-form__textarea-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.input_focus_color }};
    outline-offset: 2px;
  }

  .ai-bulk-sales-form__textarea-{{ ai_gen_id }} {
    min-height: 100px;
    resize: vertical;
  }

  .ai-bulk-sales-form__button-{{ ai_gen_id }} {
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
    text-align: center;
  }

  .ai-bulk-sales-form__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-bulk-sales-form__success-{{ ai_gen_id }} {
    padding: 16px;
    background-color: {{ block.settings.success_background }};
    color: {{ block.settings.success_text_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    margin-bottom: {{ block.settings.field_spacing }}px;
  }

  .ai-bulk-sales-form__errors-{{ ai_gen_id }} {
    padding: 16px;
    background-color: {{ block.settings.error_background }};
    color: {{ block.settings.error_text_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    margin-bottom: {{ block.settings.field_spacing }}px;
  }

  .ai-bulk-sales-form__errors-{{ ai_gen_id }} ul {
    margin: 0;
    padding-left: 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-bulk-sales-form-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.form_padding | times: 0.6 }}px;
    }
  }
{% endstyle %}

<div class="ai-bulk-sales-form-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <h2 class="ai-bulk-sales-form__heading-{{ ai_gen_id }}">
    {{ block.settings.heading }}
  </h2>

  {% form 'contact' %}
    {% if form.posted_successfully? %}
      <div class="ai-bulk-sales-form__success-{{ ai_gen_id }}">
        {{ block.settings.success_message }}
      </div>
    {% endif %}

    {% if form.errors %}
      <div class="ai-bulk-sales-form__errors-{{ ai_gen_id }}">
        {{ form.errors | default_errors }}
      </div>
    {% endif %}

    <div class="ai-bulk-sales-form__form-{{ ai_gen_id }}">
      <div class="ai-bulk-sales-form__field-{{ ai_gen_id }}">
        <label class="ai-bulk-sales-form__label-{{ ai_gen_id }}">
          Full Name *
        </label>
        <input
          type="text"
          name="contact[name]"
          class="ai-bulk-sales-form__input-{{ ai_gen_id }}"
          required
          pattern="[A-Za-z\s]+"
          title="Name should contain letters only"
        >
      </div>

      <div class="ai-bulk-sales-form__field-{{ ai_gen_id }}">
        <label class="ai-bulk-sales-form__label-{{ ai_gen_id }}">
          Company Name
        </label>
        <input
          type="text"
          name="contact[Company]"
          class="ai-bulk-sales-form__input-{{ ai_gen_id }}"
          pattern="[A-Za-z\s&]+"
          title="Company name should contain letters only"
        >
      </div>

      <div class="ai-bulk-sales-form__field-{{ ai_gen_id }}">
        <label class="ai-bulk-sales-form__label-{{ ai_gen_id }}">
          Email Address *
        </label>
        <input
          type="email"
          name="contact[email]"
          class="ai-bulk-sales-form__input-{{ ai_gen_id }}"
          required
        >
      </div>

      <div class="ai-bulk-sales-form__field-{{ ai_gen_id }}">
        <label class="ai-bulk-sales-form__label-{{ ai_gen_id }}">
          Phone Number *
        </label>
        <input
          type="tel"
          name="contact[Phone]"
          class="ai-bulk-sales-form__input-{{ ai_gen_id }}"
          required
          pattern="[0-9]{10,15}"
          title="Please enter a valid phone number (10-15 digits only)"
        >
      </div>

      {% capture all_books_options %}
        {% paginate collections['books'].products by 250 %}
          {% for product in collections['books'].products %}
            {% if product.available %}
              <option value="{{ product.title }}">
                {{ product.title }}
              </option>
            {% endif %}
          {% endfor %}
        {% endpaginate %}
      {% endcapture %}

      <div class="ai-bulk-sales-form__field-{{ ai_gen_id }}">
        <label class="ai-bulk-sales-form__label-{{ ai_gen_id }}">
          Book Title *
        </label>
        <select
          name="contact[Book Title]"
          class="ai-bulk-sales-form__select-{{ ai_gen_id }}"
          required
        >
          <option value="">Select a Book</option>
          {{ all_books_options }}
        </select>
      </div>

      <div class="ai-bulk-sales-form__field-{{ ai_gen_id }}">
        <label class="ai-bulk-sales-form__label-{{ ai_gen_id }}">
          Quantity *
        </label>
        <input
          type="number"
          name="contact[Quantity]"
          class="ai-bulk-sales-form__input-{{ ai_gen_id }}"
          min="1"
          required
        >
      </div>

      <div class="ai-bulk-sales-form__field-{{ ai_gen_id }}">
        <label class="ai-bulk-sales-form__label-{{ ai_gen_id }}">
          Additional Notes
        </label>
        <textarea
          name="contact[Notes]"
          class="ai-bulk-sales-form__textarea-{{ ai_gen_id }}"
          pattern="[A-Za-z0-9\s.,-]+"
          title="Only letters, numbers, comma, dot and dash allowed"
        ></textarea>
      </div>

      <button type="submit" class="ai-bulk-sales-form__button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </button>
    </div>
  {% endform %}
</div>

