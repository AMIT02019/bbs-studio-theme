{% doc %}
  @prompt
    <div class="bulk-sales-container form-align-{{ section.settings.form_alignment }}">
      <h1>Bulk Sales Inquiry</h1>
    
      {% form 'contact' %}
        
        {% if form.posted_successfully? %}
          <p class="success-message">
            Thank you. Our supplier will contact you shortly regarding your bulk order.
          </p>
        {% endif %}
    
        {{ form.errors | default_errors }}
    
        <label>Full Name *</label>
        <input type="text" name="contact[name]" required>
    
        <label>Company Name</label>
        <input type="text" name="contact[Company]">
    
        <label>Email Address *</label>
        <input type="email" name="contact[email]" required>
    
        <label>Phone Number *</label>
        <input type="tel" name="contact[Phone]" required>
    
       {% capture all_books_options %}
  {% paginate collections['books'].products by 500 %}
    {% for product in collections['books'].products %}
      {% if product.available %}
        <option value="{{ product.title }}">
          {{ product.title }}
        </option>
      {% endif %}
    {% endfor %}
  {% endpaginate %}
{% endcapture %}

<label>Book Title *</label>
<select name="contact[Book Title]" required>
  <option value="">Select a Book</option>
  {{ all_books_options }}
</select>
     
        <label>Quantity *</label>
        <input type="number" name="contact[Quantity]" min="1" required>
    
        <label>Additional Notes</label>
        <textarea name="contact[Notes]"></textarea>
    
        <button type="submit">Submit Bulk Request</button>
    
      {% endform %}
    </div>
    
    <style>
    .bulk-sales-container{
      max-width:600px;
      padding:20px;
    }
    
    .bulk-sales-container h1{
      text-align:center;
      margin-bottom:30px;
    }
    
    .bulk-sales-container input,
    .bulk-sales-container select,
    .bulk-sales-container textarea{
      width:100%;
      padding:10px;
      margin-bottom:15px;
      box-sizing:border-box;
    }
    
    .bulk-sales-container button{
      width:100%;
      padding:12px;
      background:#000;
      color:#fff;
      border:none;
      cursor:pointer;
    }
    
    .success-message{
      color:green;
      font-weight:bold;
      margin-bottom:20px;
    }
    
    /* Alignment Options */
    .form-align-left{
      margin:40px 0 40px 0;
    }
    
    .form-align-center{
      margin:40px auto;
    }
    
    .form-align-right{
      margin:40px 0 40px auto;
    }
    </style>
    
    {% schema %}
   "settings": [
  {
    "type": "select",
    "id": "form_alignment",
    "label": "Form Alignment",
    "default": "center",
    "options": [
      { "value": "left", "label": "Left" },
      { "value": "center", "label": "Center" },
      { "value": "right", "label": "Right" }
    ]
  },
  {
    "type": "select",
    "id": "heading_alignment",
    "label": "Heading Alignment",
    "default": "center",
    "options": [
      { "value": "left", "label": "Left" },
      { "value": "center", "label": "Center" },
      { "value": "right", "label": "Right" }
    ]
  }
]
    {% endschema %}
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-bulk-sales-form-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-bulk-sales-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.form_max_width }}px;
    padding: {{ block.settings.form_padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    box-sizing: border-box;
  }

  .ai-bulk-sales-container-{{ ai_gen_id }}.ai-align-left-{{ ai_gen_id }} {
    margin: {{ block.settings.vertical_spacing }}px 0;
  }

  .ai-bulk-sales-container-{{ ai_gen_id }}.ai-align-center-{{ ai_gen_id }} {
    margin: {{ block.settings.vertical_spacing }}px auto;
  }

  .ai-bulk-sales-container-{{ ai_gen_id }}.ai-align-right-{{ ai_gen_id }} {
    margin: {{ block.settings.vertical_spacing }}px 0 {{ block.settings.vertical_spacing }}px auto;
  }

  .ai-bulk-sales-heading-{{ ai_gen_id }} {
    text-align: center;
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px 0;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_font_size }}px;
  }

  .ai-bulk-sales-label-{{ ai_gen_id }} {
    display: block;
    margin-bottom: 8px;
    color: {{ block.settings.label_color }};
    font-size: {{ block.settings.label_font_size }}px;
    font-weight: {{ block.settings.label_font_weight }};
  }

  .ai-bulk-sales-input-{{ ai_gen_id }},
  .ai-bulk-sales-select-{{ ai_gen_id }},
  .ai-bulk-sales-textarea-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.input_padding }}px;
    margin-bottom: {{ block.settings.input_margin_bottom }}px;
    box-sizing: border-box;
    border: {{ block.settings.input_border_width }}px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    background-color: {{ block.settings.input_background_color }};
    color: {{ block.settings.input_text_color }};
    font-size: {{ block.settings.input_font_size }}px;
  }

  .ai-bulk-sales-input-{{ ai_gen_id }}:focus,
  .ai-bulk-sales-select-{{ ai_gen_id }}:focus,
  .ai-bulk-sales-textarea-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.input_focus_color }};
    outline-offset: 2px;
  }

  .ai-bulk-sales-textarea-{{ ai_gen_id }} {
    min-height: 100px;
    resize: vertical;
  }

  .ai-bulk-sales-button-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-transform: {{ block.settings.button_text_transform }};
    transition: background-color 0.3s ease;
  }

  .ai-bulk-sales-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-bulk-sales-success-{{ ai_gen_id }} {
    color: {{ block.settings.success_color }};
    font-weight: 600;
    margin-bottom: 20px;
    padding: 12px;
    background-color: {{ block.settings.success_background }};
    border-radius: {{ block.settings.input_border_radius }}px;
  }

  .ai-bulk-sales-errors-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
    margin-bottom: 20px;
    padding: 12px;
    background-color: {{ block.settings.error_background }};
    border-radius: {{ block.settings.input_border_radius }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-bulk-sales-container-{{ ai_gen_id }} {
      padding: {{ block.settings.form_padding | times: 0.7 }}px;
    }

    .ai-bulk-sales-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<bulk-sales-form-{{ ai_gen_id }} class="ai-bulk-sales-form-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-bulk-sales-container-{{ ai_gen_id }} ai-align-{{ block.settings.form_alignment }}-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-bulk-sales-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% form 'contact' %}
      {% if form.posted_successfully? %}
        <div class="ai-bulk-sales-success-{{ ai_gen_id }}">
          {{ block.settings.success_message }}
        </div>
      {% endif %}

      {% if form.errors %}
        <div class="ai-bulk-sales-errors-{{ ai_gen_id }}">
          {{ form.errors | default_errors }}
        </div>
      {% endif %}

      <label class="ai-bulk-sales-label-{{ ai_gen_id }}" for="ai-name-{{ ai_gen_id }}">
        {{ block.settings.label_name }}
      </label>
      <input
        type="text"
        id="ai-name-{{ ai_gen_id }}"
        name="contact[name]"
        class="ai-bulk-sales-input-{{ ai_gen_id }}"
        required
      >

      <label class="ai-bulk-sales-label-{{ ai_gen_id }}" for="ai-company-{{ ai_gen_id }}">
        {{ block.settings.label_company }}
      </label>
      <input
        type="text"
        id="ai-company-{{ ai_gen_id }}"
        name="contact[Company]"
        class="ai-bulk-sales-input-{{ ai_gen_id }}"
      >

      <label class="ai-bulk-sales-label-{{ ai_gen_id }}" for="ai-email-{{ ai_gen_id }}">
        {{ block.settings.label_email }}
      </label>
      <input
        type="email"
        id="ai-email-{{ ai_gen_id }}"
        name="contact[email]"
        class="ai-bulk-sales-input-{{ ai_gen_id }}"
        required
      >

      <label class="ai-bulk-sales-label-{{ ai_gen_id }}" for="ai-phone-{{ ai_gen_id }}">
        {{ block.settings.label_phone }}
      </label>
      <input
        type="tel"
        id="ai-phone-{{ ai_gen_id }}"
        name="contact[Phone]"
        class="ai-bulk-sales-input-{{ ai_gen_id }}"
        required
      >

      <label class="ai-bulk-sales-label-{{ ai_gen_id }}" for="ai-book-{{ ai_gen_id }}">
        {{ block.settings.label_book }}
      </label>
      <select
        id="ai-book-{{ ai_gen_id }}"
        name="contact[Book Title]"
        class="ai-bulk-sales-select-{{ ai_gen_id }}"
        required
      >
        <option value="">{{ block.settings.book_placeholder }}</option>
        {% if block.settings.books_collection != blank %}
          {% for product in block.settings.books_collection.products %}
            {% if product.available %}
              <option value="{{ product.title }}">{{ product.title }}</option>
            {% endif %}
          {% endfor %}
        {% endif %}
      </select>

      <label class="ai-bulk-sales-label-{{ ai_gen_id }}" for="ai-quantity-{{ ai_gen_id }}">
        {{ block.settings.label_quantity }}
      </label>
      <input
        type="number"
        id="ai-quantity-{{ ai_gen_id }}"
        name="contact[Quantity]"
        min="1"
        class="ai-bulk-sales-input-{{ ai_gen_id }}"
        required
      >

      <label class="ai-bulk-sales-label-{{ ai_gen_id }}" for="ai-notes-{{ ai_gen_id }}">
        {{ block.settings.label_notes }}
      </label>
      <textarea
        id="ai-notes-{{ ai_gen_id }}"
        name="contact[Notes]"
        class="ai-bulk-sales-textarea-{{ ai_gen_id }}"
      ></textarea>

      <button type="submit" class="ai-bulk-sales-button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </button>
    {% endform %}
  </div>
</bulk-sales-form-{{ ai_gen_id }}>

<script>
  (function() {
    class BulkSalesForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.form = this.querySelector('form');
        if (this.form) {
          this.form.addEventListener('submit', this.handleSubmit.bind(this));
        }
      }

      handleSubmit(event) {
        const requiredFields = this.form.querySelectorAll('[required]');
        let isValid = true;

        requiredFields.forEach(field => {
          if (!field.value.trim()) {
            isValid = false;
            field.style.borderColor = '{{ block.settings.error_color }}';
          } else {
            field.style.borderColor = '{{ block.settings.input_border_color }}';
          }
        });

        if (!isValid) {
          event.preventDefault();
        }
      }
    }

    customElements.define('bulk-sales-form-{{ ai_gen_id }}', BulkSalesForm{{ ai_gen_id }});
  })();
</script>

