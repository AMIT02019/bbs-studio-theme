{% doc %}
  @prompt
    <div class="bulk-sales-container form-align-{{ section.settings.form_alignment }}">
      
      <h1 class="heading-align-{{ section.settings.heading_alignment }}">
        Bulk Sales Inquiry
      </h1>
    
      {% form 'contact' %}
        
        {% if form.posted_successfully? %}
          <p class="success-message">
            Thank you. Our supplier will contact you shortly regarding your bulk order.
          </p>
        {% endif %}
    
        {{ form.errors | default_errors }}
    
        <label>Full Name *</label>
        <input type="text" name="contact[name]" required>
    
        <label>Company Name</label>
        <input type="text" name="contact[Company]">
    
        <label>Email Address *</label>
        <input type="email" name="contact[email]" required>
    
        <label>Phone Number *</label>
        <input type="tel" name="contact[Phone]" required>
    
        {% capture all_books_options %}
          {% paginate collections['books'].products by 250 %}
            {% for product in collections['books'].products %}
              {% if product.available %}
                <option value="{{ product.title }}">
                  {{ product.title }}
                </option>
              {% endif %}
            {% endfor %}
          {% endpaginate %}
        {% endcapture %}
    
        <label>Book Title *</label>
        <select name="contact[Book Title]" required>
          <option value="">Select a Book</option>
          {{ all_books_options }}
        </select>
    
        <label>Quantity *</label>
        <input type="number" name="contact[Quantity]" min="1" required>
    
        <label>Additional Notes</label>
        <textarea name="contact[Notes]"></textarea>
    
        <button type="submit">Submit Bulk Request</button>
    
      {% endform %}
    </div>
    
    <style>
    .bulk-sales-container{
      max-width:600px;
      padding:20px;
    }
    
    .bulk-sales-container h1{
      margin-bottom:30px;
    }
    
    /* Heading Alignment */
    .heading-align-left{
      text-align:left;
    }
    
    .heading-align-center{
      text-align:center;
    }
    
    .heading-align-right{
      text-align:right;
    }
    
    .bulk-sales-container input,
    .bulk-sales-container select,
    .bulk-sales-container textarea{
      width:100%;
      padding:10px;
      margin-bottom:15px;
      box-sizing:border-box;
    }
    
    .bulk-sales-container button{
      width:100%;
      padding:12px;
      background:#000;
      color:#fff;
      border:none;
      cursor:pointer;
    }
    
    .success-message{
      color:green;
      font-weight:bold;
      margin-bottom:20px;
    }
    
    /* Form Alignment */
    .form-align-left{
      margin:40px 0 40px 0;
    }
    
    .form-align-center{
      margin:40px auto;
    }
    
    .form-align-right{
      margin:40px 0 40px auto;
    }
    </style>
    
    {% schema %}
    {
      "name": "Bulk Sales Form",
      "settings": [
        {
          "type": "select",
          "id": "form_alignment",
          "label": "Form Alignment",
          "default": "center",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ]
        },
        {
          "type": "select",
          "id": "heading_alignment",
          "label": "Heading Alignment",
          "default": "center",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ]
        }
      ]
    }
    {% endschema %}
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-bulk-sales-form-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-bulk-sales-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.form_max_width }}px;
    padding: {{ block.settings.form_padding }}px;
    background-color: {{ block.settings.form_background_color }};
    border-radius: {{ block.settings.form_border_radius }}px;
    margin: 40px auto;
  }

  .ai-bulk-sales-container-{{ ai_gen_id }}.ai-form-align-left-{{ ai_gen_id }} {
    margin-left: 0;
    margin-right: auto;
  }

  .ai-bulk-sales-container-{{ ai_gen_id }}.ai-form-align-center-{{ ai_gen_id }} {
    margin-left: auto;
    margin-right: auto;
  }

  .ai-bulk-sales-container-{{ ai_gen_id }}.ai-form-align-right-{{ ai_gen_id }} {
    margin-left: auto;
    margin-right: 0;
  }

  .ai-bulk-sales-heading-{{ ai_gen_id }} {
    margin: 0 0 30px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_font_size }}px;
  }

  .ai-bulk-sales-heading-{{ ai_gen_id }}.ai-heading-align-left-{{ ai_gen_id }} {
    text-align: left;
  }

  .ai-bulk-sales-heading-{{ ai_gen_id }}.ai-heading-align-center-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-bulk-sales-heading-{{ ai_gen_id }}.ai-heading-align-right-{{ ai_gen_id }} {
    text-align: right;
  }

  .ai-bulk-sales-form-{{ ai_gen_id }} label {
    display: block;
    margin-bottom: 8px;
    color: {{ block.settings.label_color }};
    font-size: {{ block.settings.label_font_size }}px;
    font-weight: 500;
  }

  .ai-bulk-sales-form-{{ ai_gen_id }} input,
  .ai-bulk-sales-form-{{ ai_gen_id }} select,
  .ai-bulk-sales-form-{{ ai_gen_id }} textarea {
    width: 100%;
    padding: 12px;
    margin-bottom: 20px;
    box-sizing: border-box;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    background-color: {{ block.settings.input_background_color }};
    color: {{ block.settings.input_text_color }};
    font-size: {{ block.settings.input_font_size }}px;
  }

  .ai-bulk-sales-form-{{ ai_gen_id }} input:focus,
  .ai-bulk-sales-form-{{ ai_gen_id }} select:focus,
  .ai-bulk-sales-form-{{ ai_gen_id }} textarea:focus {
    outline: 2px solid {{ block.settings.input_focus_color }};
    outline-offset: 2px;
  }

  .ai-bulk-sales-form-{{ ai_gen_id }} textarea {
    min-height: 100px;
    resize: vertical;
  }

  .ai-bulk-sales-form-{{ ai_gen_id }} button {
    width: 100%;
    padding: 14px 24px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    transition: background-color 0.3s ease;
  }

  .ai-bulk-sales-form-{{ ai_gen_id }} button:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-bulk-sales-success-{{ ai_gen_id }} {
    color: {{ block.settings.success_message_color }};
    font-weight: 600;
    margin-bottom: 20px;
    padding: 12px;
    background-color: {{ block.settings.success_background_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
  }

  .ai-bulk-sales-errors-{{ ai_gen_id }} {
    color: {{ block.settings.error_message_color }};
    margin-bottom: 20px;
    padding: 12px;
    background-color: {{ block.settings.error_background_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
  }

  .ai-bulk-sales-errors-{{ ai_gen_id }} ul {
    margin: 0;
    padding-left: 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-bulk-sales-container-{{ ai_gen_id }} {
      padding: {{ block.settings.form_padding | times: 0.5 }}px;
      margin-left: 0;
      margin-right: 0;
    }

    .ai-bulk-sales-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<bulk-sales-form-{{ ai_gen_id }}
  class="ai-bulk-sales-form-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-bulk-sales-container-{{ ai_gen_id }} ai-form-align-{{ block.settings.form_alignment }}-{{ ai_gen_id }}">
    <h1 class="ai-bulk-sales-heading-{{ ai_gen_id }} ai-heading-align-{{ block.settings.heading_alignment }}-{{ ai_gen_id }}">
      {{ block.settings.form_heading }}
    </h1>

    {%- form 'contact' -%}
      {%- if form.posted_successfully? -%}
        <div class="ai-bulk-sales-success-{{ ai_gen_id }}">
          {{ block.settings.success_message }}
        </div>
      {%- endif -%}

      {%- if form.errors -%}
        <div class="ai-bulk-sales-errors-{{ ai_gen_id }}">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <!-- NAME (Alphabet Only) -->
<label class="ai-bulk-sales-label-{{ ai_gen_id }}" for="contact-name-{{ ai_gen_id }}">
  {{ block.settings.name_label }}{% if block.settings.name_required %} *{% endif %}
</label>
<input
  type="text"
  id="contact-name-{{ ai_gen_id }}"
  name="contact[name]"
  class="ai-bulk-sales-input-{{ ai_gen_id }}"
  pattern="[A-Za-z\s]+"
  title="Only letters are allowed"
  {% if block.settings.name_required %}required{% endif %}
>

<!-- COMPANY (Alphabet Only) -->
<label class="ai-bulk-sales-label-{{ ai_gen_id }}" for="contact-company-{{ ai_gen_id }}">
  {{ block.settings.company_label }}{% if block.settings.company_required %} *{% endif %}
</label>
<input
  type="text"
  id="contact-company-{{ ai_gen_id }}"
  name="contact[Company]"
  class="ai-bulk-sales-input-{{ ai_gen_id }}"
  pattern="[A-Za-z\s]+"
  title="Only letters are allowed"
  {% if block.settings.company_required %}required{% endif %}
>

<!-- EMAIL -->
<label class="ai-bulk-sales-label-{{ ai_gen_id }}" for="contact-email-{{ ai_gen_id }}">
  {{ block.settings.email_label }} *
</label>
<input
  type="email"
  id="contact-email-{{ ai_gen_id }}"
  name="contact[email]"
  class="ai-bulk-sales-input-{{ ai_gen_id }}"
  required
>

<!-- PHONE (Numbers Only) -->
<label class="ai-bulk-sales-label-{{ ai_gen_id }}" for="contact-phone-{{ ai_gen_id }}">
  {{ block.settings.phone_label }}{% if block.settings.phone_required %} *{% endif %}
</label>
<input
  type="tel"
  id="contact-phone-{{ ai_gen_id }}"
  name="contact[Phone]"
  class="ai-bulk-sales-input-{{ ai_gen_id }}"
  pattern="[0-9]+"
  title="Only numbers are allowed"
  {% if block.settings.phone_required %}required{% endif %}
>

<!-- QUANTITY (Numbers Only) -->
<label class="ai-bulk-sales-label-{{ ai_gen_id }}" for="contact-quantity-{{ ai_gen_id }}">
  {{ block.settings.quantity_label }} *
</label>
<input
  type="number"
  id="contact-quantity-{{ ai_gen_id }}"
  name="contact[Quantity]"
  min="1"
  class="ai-bulk-sales-input-{{ ai_gen_id }}"
  required
>

<!-- NOTES (Letters + Numbers Only) -->
<label class="ai-bulk-sales-label-{{ ai_gen_id }}" for="contact-notes-{{ ai_gen_id }}">
  {{ block.settings.notes_label }}
</label>
<textarea
  id="contact-notes-{{ ai_gen_id }}"
  name="contact[Notes]"
  class="ai-bulk-sales-textarea-{{ ai_gen_id }}"
  pattern="[A-Za-z0-9\s.,-]+"
  title="Only letters and numbers allowed"
></textarea>

      <button type="submit">{{ block.settings.button_text }}</button>
    {%- endform -%}
  </div>
</bulk-sales-form-{{ ai_gen_id }}>

<script>
(function() {

  function applyRestrictions() {

    const nameInputs = document.querySelectorAll('input[name="contact[name]"]');
    const companyInputs = document.querySelectorAll('input[name="contact[Company]"]');
    const phoneInputs = document.querySelectorAll('input[name="contact[Phone]"]');
    const quantityInputs = document.querySelectorAll('input[name="contact[Quantity]"]');
    const notesInputs = document.querySelectorAll('textarea[name="contact[Notes]"]');

    nameInputs.forEach(input => {
      input.oninput = function() {
        this.value = this.value.replace(/[^A-Za-z\s]/g, '');
      };
    });

    companyInputs.forEach(input => {
      input.oninput = function() {
        this.value = this.value.replace(/[^A-Za-z\s]/g, '');
      };
    });

    phoneInputs.forEach(input => {
      input.oninput = function() {
        this.value = this.value.replace(/[^0-9]/g, '');
      };
    });

    quantityInputs.forEach(input => {
      input.oninput = function() {
        this.value = this.value.replace(/[^0-9]/g, '');
      };
    });

    notesInputs.forEach(input => {
      input.oninput = function() {
        this.value = this.value.replace(/[^A-Za-z0-9\s.,-]/g, '');
      };
    });

  }

  // Run immediately
  applyRestrictions();

  // Re-run when Shopify dynamically reloads sections
  document.addEventListener("shopify:section:load", applyRestrictions);

})();
</script>

