{% doc %}
  @prompt
    Create a premium “Our Story” section for a luxury vintage boutique Shopify website with a clean editorial layout and sophisticated minimalist aesthetic.
    
    SECTION STYLE:
    - Elegant luxury fashion brand design
    - Minimal editorial layout
    - High-end boutique storytelling feel
    - Soft neutral background
    - Warm cinematic imagery
    - Modern vintage aesthetic
    - Calm, refined, and premium atmosphere
    
    LAYOUT:
    - Two-column split layout
    - Left side: text content
    - Right side: large lifestyle image
    - Full-width section
    - Vertically centered alignment
    - Large white/cream background space
    - Spacious luxury composition
    
    LEFT CONTENT AREA:
    Include:
    - Large heading
    - Paragraph description
    - Luxury CTA button
    
    TEXT CONTENT:
    Heading:
    “OUR STORY”
    
    Body Text:
    A high-end boutique thrift store based in Mumbai, known for curated vintage treasures, designer labels, luxury jewellery, and timeless collectibles. The brand blends vintage elegance with modern storytelling and showcases carefully sourced pieces from around the world.
    
    BUTTON:
    Text:
    “KNOW MORE →”
    
    TYPOGRAPHY:
    - Heading:
      - Large uppercase typography
      - Dark brown / espresso color
      - Bold luxury sans-serif
      - Clean editorial spacing
    - Paragraph:
      - Soft gray text
      - Medium line height
      - Elegant readable font
      - Minimal luxury style
    - Button:
      - Dark charcoal background
      - White uppercase text
      - Minimal rectangular shape
      - Thin arrow icon
      - Smooth hover transition
    
    RIGHT IMAGE AREA:
    - Large portrait-style image
    - Warm cinematic lighting
    - Vintage luxury objects and jewellery
    - Moody shadows
    - Antique editorial aesthetic
    - Full-height image crop
    - Object-fit cover
    - Soft luxury ambiance
    
    SPACING:
    - Generous padding top and bottom
    - Wide margins
    - Balanced whitespace
    - Luxury editorial proportions
    - Image and text evenly aligned
    
    COLORS:
    - Background: soft off-white / light beige
    - Heading: dark brown
    - Paragraph: muted gray
    - Button: charcoal gray
    - Overall warm vintage tones
    
    HOVER EFFECTS:
    - Button slightly brightens on hover
    - Smooth fade transition
    - Optional subtle image zoom
    
    MOBILE VERSION:
    - Stack image below text
    - Center-align content
    - Reduce heading size
    - Maintain elegant spacing
    - Full-width responsive image
    
    SHOPIFY REQUIREMENTS:
    - Build as editable Shopify section
    - Editable heading
    - Editable paragraph
    - Editable button text/link
    - Editable image
    - Adjustable spacing controls
    - Optimized for Dawn theme
    - Responsive and lightweight
    
    OVERALL GOAL:
    The section should feel like a luxury editorial fashion boutique telling its brand story through elegant typography, spacious layout, and warm cinematic imagery — inspired by premium vintage and designer lifestyle brands.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-our-story-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
  }

  .ai-our-story-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-our-story-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.column_gap }}px;
    align-items: center;
  }

  .ai-our-story-content-{{ ai_gen_id }} {
    padding-right: 40px;
  }

  .ai-our-story-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    color: {{ block.settings.heading_color }};
    text-transform: uppercase;
    letter-spacing: {{ block.settings.heading_letter_spacing }};
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px;
    line-height: 1.2;
  }

  .ai-our-story-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: {{ block.settings.text_line_height }};
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.text_margin_bottom }}px;
  }

  .ai-our-story-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    text-transform: uppercase;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    letter-spacing: {{ block.settings.button_letter_spacing }};
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: background-color 0.3s ease, transform 0.3s ease;
  }

  .ai-our-story-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_bg_hover_color }};
    transform: translateY(-2px);
  }

  .ai-our-story-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-our-story-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  {% if block.settings.enable_image_zoom %}
    .ai-our-story-image-wrapper-{{ ai_gen_id }}:hover .ai-our-story-image-{{ ai_gen_id }} {
      transform: scale(1.05);
    }
  {% endif %}

  .ai-our-story-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 3 / 4;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-our-story-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
    opacity: 0.3;
  }

  @media screen and (max-width: 989px) {
    .ai-our-story-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .ai-our-story-content-{{ ai_gen_id }} {
      padding-right: 0;
      text-align: {{ block.settings.mobile_text_align }};
    }

    .ai-our-story-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-our-story-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }

    .ai-our-story-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<our-story-{{ ai_gen_id }} class="ai-our-story-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-our-story-container-{{ ai_gen_id }}">
    <div class="ai-our-story-grid-{{ ai_gen_id }}">
      <div class="ai-our-story-content-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-our-story-heading-{{ ai_gen_id }}">
            {{ block.settings.heading }}
          </h2>
        {% endif %}

        {% if block.settings.description != blank %}
          <div class="ai-our-story-description-{{ ai_gen_id }}">
            {{ block.settings.description }}
          </div>
        {% endif %}

        {% if block.settings.button_text != blank %}
          <a 
            href="{{ block.settings.button_link }}" 
            class="ai-our-story-button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_text }}
          </a>
        {% endif %}
      </div>

      <div class="ai-our-story-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 1200 }}"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
            class="ai-our-story-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-our-story-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</our-story-{{ ai_gen_id }}>

<script>
  (function() {
    class OurStory{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('our-story-{{ ai_gen_id }}', OurStory{{ ai_gen_id }});
  })();
</script>

