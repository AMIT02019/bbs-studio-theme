{% doc %}
  @prompt
    create a collection list i want to call all the authores in one row i want five crds or more in this card first i wnt image and then name about author and them view all books button, no i have one specific collection i want to call the collection so all the collection wil automeacaly come i don't want to manualy  select the collection each time.
    ther should not be a limit for shuold  in a section
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-author-collection-list-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-author-collection-container-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-author-collection-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.cards_per_row }}, 1fr);
    gap: {{ block.settings.card_gap }}px;
    width: 100%;
  }

  .ai-author-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_bg_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
  }

  .ai-author-card-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .ai-author-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    margin-bottom: {{ block.settings.image_margin_bottom }}px;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-author-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
  }

  .ai-author-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-author-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-author-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.name_font_size }}px;
    font-weight: {{ block.settings.name_font_weight }};
    color: {{ block.settings.name_color }};
    margin: 0 0 {{ block.settings.name_margin_bottom }}px;
    text-transform: {{ block.settings.name_text_transform }};
  }

  .ai-author-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0 0 {{ block.settings.description_margin_bottom }}px;
    line-height: 1.5;
  }

  .ai-author-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    transition: background-color 0.3s ease, color 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
  }

  .ai-author-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-author-collection-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.cards_per_row_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-author-collection-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.cards_per_row_mobile }}, 1fr);
    }
  }
{% endstyle %}

<author-collection-list-{{ ai_gen_id }}
  class="ai-author-collection-list-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-author-collection-container-{{ ai_gen_id }}">
    <div class="ai-author-collection-grid-{{ ai_gen_id }}">
      {% for collection in collections %}
        <div class="ai-author-card-{{ ai_gen_id }}">
          <div class="ai-author-image-wrapper-{{ ai_gen_id }}">
            {% if collection.image %}
              <img
                src="{{ collection.image | image_url: width: 600 }}"
                alt="{{ collection.title | escape }}"
                class="ai-author-image-{{ ai_gen_id }}"
                loading="lazy"
                width="600"
                height="{{ 600 | divided_by: block.settings.image_aspect_ratio | round }}"
              >
            {% else %}
              <div class="ai-author-image-placeholder-{{ ai_gen_id }}">
                {{ 'collection-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <h3 class="ai-author-name-{{ ai_gen_id }}">{{ collection.title }}</h3>

          {% if collection.description != blank %}
            <div class="ai-author-description-{{ ai_gen_id }}">
              {{ collection.description | strip_html | truncate: block.settings.description_length }}
            </div>
          {% endif %}

          <a
            href="{{ collection.url }}"
            class="ai-author-button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_text }}
          </a>
        </div>
      {% endfor %}
    </div>
  </div>
</author-collection-list-{{ ai_gen_id }}>

<script>
  (function() {
    class AuthorCollectionList{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('author-collection-list-{{ ai_gen_id }}', AuthorCollectionList{{ ai_gen_id }});
  })();
</script>

