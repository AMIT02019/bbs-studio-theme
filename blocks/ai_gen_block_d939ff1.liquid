<script>
  (function() {
    class AuthorScroll{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.adjustAnimation();
      }

      adjustAnimation() {
        const track = this.querySelector('.ai-author-scroll__track-{{ ai_gen_id }}');
        if (!track) return;

        const items = track.querySelectorAll('.ai-author-scroll__item-{{ ai_gen_id }}:not([aria-hidden="true"])');
        if (items.length === 0) return;

        const totalWidth = Array.from(items).reduce((sum, item) => {
          return sum + item.offsetWidth + 30;
        }, 0);

        const viewportWidth = this.offsetWidth;

        if (totalWidth < viewportWidth) {
          track.style.animation = 'none';
        }
      }
    }

    customElements.define('author-scroll-{{ ai_gen_id }}', AuthorScroll{{ ai_gen_id }});
  })();
</script>

