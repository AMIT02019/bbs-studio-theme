{% doc %}
  @prompt
    🔹 Core Requirements
    Multiple Collections
    
    Use section blocks.
    
    Each block allows selecting one collection.
    
    There must be no limit on blocks.
    
    Each block represents one author collection.
    
    Do NOT loop through products.
    
    Do NOT display product data.
    
    Only display:
    
    Collection image
    
    Collection title
    
    🔹 Infinite Horizontal Scroll (Important)
    
    Implement a true infinite horizontal scroll animation, not just overflow scroll.
    
    Requirements:
    
    Authors should scroll continuously from right to left.
    
    When the last item exits, it should seamlessly repeat.
    
    No visible jump or reset.
    
    Must duplicate the collection list in Liquid to create a smooth loop.
    
    Animation must be pure CSS (preferred) or minimal JS if necessary.
    
    Must pause on hover.
    
    Must work on all screen sizes.
    
    Must not break layout responsiveness.
    
    🔹 Redirect Logic
    
    When user clicks:
    
    Collection image OR
    
    Collection title
    
    Redirect dynamically to:
    
    /collections/{collection-handle}
    
    
    Use collection.url dynamically.
    Do NOT hardcode URLs.
    
    🔹 Section Settings
    
    Include:
    
    1️⃣ Section Title
    
    Text field
    
    Default: "Meet Our Authors"
    
    Output as <h2>
    
    2️⃣ Image Size
    
    Range slider (100px – 300px)
    
    3️⃣ Image Shape
    Options:
    
    Circle (50%)
    
    Square (0)
    
    Rounded (12px)
    
    4️⃣ Scroll Speed
    
    Range slider (10–60 seconds animation duration)
    
    Controls animation speed
    
    5️⃣ Pause on Hover
    
    Checkbox toggle
    
    6️⃣ Padding Top
    
    Range (0–120px)
    
    7️⃣ Padding Bottom
    
    Range (0–120px)
    
    🔹 Layout & Design
    
    Clean modern design
    
    Items aligned horizontally
    
    Equal spacing between items
    
    Fully responsive
    
    No wrapping
    
    Overflow hidden
    
    Smooth animation
    
    🔹 Technical Requirements
    
    Shopify 2.0 compatible
    
    Proper JSON schema
    
    Uses image_url
    
    Uses loading="lazy"
    
    Accessible alt text
    
    CSS scoped only to section
    
    No global conflicts
    
    Must save without syntax errors
    
    Fully dynamic
    
    Production-ready
    
    🔹 Output
    
    Generate the complete .liquid section file including:
    
    HTML
    
    Liquid
    
    CSS (with keyframe animation)
    
    JSON schema
    
    Section blocks
    
    No errors
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-author-scroll-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    overflow: hidden;
  }

  .ai-author-scroll__title-{{ ai_gen_id }} {
    text-align: center;
    margin: 0 0 40px;
    font-size: 32px;
    font-weight: 600;
  }

  .ai-author-scroll__wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ai-author-scroll__track-{{ ai_gen_id }} {
    display: flex;
    gap: 30px;
    animation: ai-author-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
  }

  {% if block.settings.pause_on_hover %}
    .ai-author-scroll__track-{{ ai_gen_id }}:hover {
      animation-play-state: paused;
    }
  {% endif %}

  .ai-author-scroll__item-{{ ai_gen_id }} {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 15px;
    text-decoration: none;
    transition: transform 0.3s ease;
  }

  .ai-author-scroll__item-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
  }

  .ai-author-scroll__image-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.image_size }}px;
    height: {{ block.settings.image_size }}px;
    overflow: hidden;
    {% if block.settings.image_shape == 'circle' %}
      border-radius: 50%;
    {% elsif block.settings.image_shape == 'rounded' %}
      border-radius: 12px;
    {% else %}
      border-radius: 0;
    {% endif %}
  }

  .ai-author-scroll__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-author-scroll__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-author-scroll__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-author-scroll__name-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 500;
    color: #000000;
    text-align: center;
    max-width: {{ block.settings.image_size }}px;
    word-wrap: break-word;
  }

  .ai-author-scroll__empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
    font-size: 16px;
  }

  @keyframes ai-author-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-author-scroll__title-{{ ai_gen_id }} {
      font-size: 24px;
      margin-bottom: 30px;
    }

    .ai-author-scroll__image-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.image_size | times: 0.8 }}px;
      height: {{ block.settings.image_size | times: 0.8 }}px;
    }

    .ai-author-scroll__name-{{ ai_gen_id }} {
      font-size: 14px;
      max-width: {{ block.settings.image_size | times: 0.8 }}px;
    }

    .ai-author-scroll__track-{{ ai_gen_id }} {
      gap: 20px;
    }
  }
{% endstyle %}

