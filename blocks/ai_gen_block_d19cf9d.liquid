{% doc %}
  @prompt
    <div class="bulk-sales-section page-width">
    
      <h2 class="bulk-heading">{{ section.settings.heading }}</h2>
    
      {% form 'contact' %}
        
        {% if form.posted_successfully? %}
          <p class="success-message">
            {{ section.settings.success_message }}
          </p>
        {% endif %}
    
        {{ form.errors | default_errors }}
    
        <label>Full Name *</label>
        <input type="text" name="contact[name]" required>
    
        <label>Company Name</label>
        <input type="text" name="contact[Company]">
    
        <label>Email *</label>
        <input type="email" name="contact[email]" required>
    
        <label>Phone Number *</label>
        <input type="tel" name="contact[Phone]" required>
    
        <label>Book Title *</label>
        <select name="contact[Book Title]" required>
          <option value="">Select a Book</option>
          {% if section.settings.books_collection != blank %}
            {% paginate section.settings.books_collection.products by 250 %}
              {% for product in section.settings.books_collection.products %}
                {% if product.available %}
                  <option value="{{ product.title }}">{{ product.title }}</option>
                {% endif %}
              {% endfor %}
            {% endpaginate %}
          {% endif %}
        </select>
    
        <label>Quantity *</label>
        <input type="number" name="contact[Quantity]" min="1" required>
    
        <label>Additional Notes</label>
        <textarea name="contact[Notes]"></textarea>
    
        <button type="submit">Submit Bulk Request</button>
    
      {% endform %}
    </div>
    
    <style>
    .bulk-sales-section {
      max-width: 600px;
      margin: 60px auto;
    }
    
    .bulk-heading {
      text-align: center;
      margin-bottom: 30px;
    }
    
    .bulk-sales-section input,
    .bulk-sales-section select,
    .bulk-sales-section textarea {
      width: 100%;
      padding: 10px;
      margin-bottom: 15px;
      box-sizing: border-box;
    }
    
    .bulk-sales-section button {
      width: 100%;
      padding: 12px;
      background: #000;
      color: #fff;
      border: none;
      cursor: pointer;
    }
    
    .success-message {
      color: green;
      margin-bottom: 20px;
      font-weight: bold;
    }
    </style>
    
    <script>
    document.addEventListener("submit", function(e) {
    
      const form = e.target;
      if (!form.matches("form[action*='/contact']")) return;
    
      const name = form.querySelector('input[name="contact[name]"]').value.trim();
      const company = form.querySelector('input[name="contact[Company]"]').value.trim();
      const phone = form.querySelector('input[name="contact[Phone]"]').value.trim();
      const quantity = form.querySelector('input[name="contact[Quantity]"]').value.trim();
      const notes = form.querySelector('textarea[name="contact[Notes]"]').value.trim();
    
      const nameRegex = /^[A-Za-z\s]+$/;
      const companyRegex = /^[A-Za-z\s]*$/;
      const phoneRegex = /^[0-9]+$/;
      const quantityRegex = /^[0-9]+$/;
      const notesRegex = /^[A-Za-z0-9\s.,-]*$/;
    
      if (!nameRegex.test(name)) {
        alert("Name should contain letters only.");
        e.preventDefault();
        return;
      }
    
      if (company && !companyRegex.test(company)) {
        alert("Company name should contain letters only.");
        e.preventDefault();
        return;
      }
    
      if (!phoneRegex.test(phone)) {
        alert("Phone number should contain numbers only.");
        e.preventDefault();
        return;
      }
    
      if (!quantityRegex.test(quantity)) {
        alert("Quantity should contain numbers only.");
        e.preventDefault();
        return;
      }
    
      if (notes && !notesRegex.test(notes)) {
        alert("Notes can contain only letters and numbers.");
        e.preventDefault();
        return;
      }
    
    });
    </script>
    
    {% schema %}
    {
      "name": "Bulk Sales Form",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Bulk Sales Inquiry"
        },
        {
          "type": "collection",
          "id": "books_collection",
          "label": "Books collection"
        },
        {
          "type": "text",
          "id": "success_message",
          "label": "Success message",
          "default": "Thank you. We will contact you shortly."
        }
      ],
      "presets": [
        {
          "name": "Bulk Sales Form"
        }
      ]
    }
    {% endschema %}
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-bulk-sales-form-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.form_padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-bulk-sales-form__heading-{{ ai_gen_id }} {
    text-align: center;
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px 0;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_font_size }}px;
  }

  .ai-bulk-sales-form__form-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.field_spacing }}px;
  }

  .ai-bulk-sales-form__field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-bulk-sales-form__label-{{ ai_gen_id }} {
    color: {{ block.settings.label_color }};
    font-size: {{ block.settings.label_font_size }}px;
    font-weight: {{ block.settings.label_font_weight }};
  }

  .ai-bulk-sales-form__input-{{ ai_gen_id }},
  .ai-bulk-sales-form__select-{{ ai_gen_id }},
  .ai-bulk-sales-form__textarea-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.input_padding }}px;
    border: {{ block.settings.input_border_width }}px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: {{ block.settings.input_font_size }}px;
    color: {{ block.settings.input_text_color }};
    background-color: {{ block.settings.input_background_color }};
    box-sizing: border-box;
  }

  .ai-bulk-sales-form__input-{{ ai_gen_id }}:focus,
  .ai-bulk-sales-form__select-{{ ai_gen_id }}:focus,
  .ai-bulk-sales-form__textarea-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.input_focus_color }};
    outline-offset: 2px;
  }

  .ai-bulk-sales-form__textarea-{{ ai_gen_id }} {
    min-height: 100px;
    resize: vertical;
  }

  .ai-bulk-sales-form__button-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.button_padding }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-bulk-sales-form__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-bulk-sales-form__success-{{ ai_gen_id }} {
    padding: {{ block.settings.input_padding }}px;
    background-color: {{ block.settings.success_background_color }};
    color: {{ block.settings.success_text_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    margin-bottom: {{ block.settings.field_spacing }}px;
    font-weight: 600;
  }

  .ai-bulk-sales-form__errors-{{ ai_gen_id }} {
    padding: {{ block.settings.input_padding }}px;
    background-color: {{ block.settings.error_background_color }};
    color: {{ block.settings.error_text_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    margin-bottom: {{ block.settings.field_spacing }}px;
  }

  .ai-bulk-sales-form__errors-{{ ai_gen_id }} ul {
    margin: 0;
    padding-left: 20px;
  }
{% endstyle %}

<bulk-sales-form-{{ ai_gen_id }} class="ai-bulk-sales-form-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="ai-bulk-sales-form__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  {% form 'contact' %}
    <div class="ai-bulk-sales-form__form-{{ ai_gen_id }}">
      {% if form.posted_successfully? %}
        <div class="ai-bulk-sales-form__success-{{ ai_gen_id }}">
          {{ block.settings.success_message }}
        </div>
      {% endif %}

      {% if form.errors %}
        <div class="ai-bulk-sales-form__errors-{{ ai_gen_id }}">
          {{ form.errors | default_errors }}
        </div>
      {% endif %}

      <div class="ai-bulk-sales-form__field-{{ ai_gen_id }}">
        <label class="ai-bulk-sales-form__label-{{ ai_gen_id }}" for="contact-name-{{ ai_gen_id }}">
          {{ block.settings.name_label }} *
        </label>
        <input
          type="text"
          id="contact-name-{{ ai_gen_id }}"
          name="contact[name]"
          class="ai-bulk-sales-form__input-{{ ai_gen_id }}"
          required
          aria-required="true"
        >
      </div>

      <div class="ai-bulk-sales-form__field-{{ ai_gen_id }}">
        <label class="ai-bulk-sales-form__label-{{ ai_gen_id }}" for="contact-company-{{ ai_gen_id }}">
          {{ block.settings.company_label }}
        </label>
        <input
          type="text"
          id="contact-company-{{ ai_gen_id }}"
          name="contact[Company]"
          class="ai-bulk-sales-form__input-{{ ai_gen_id }}"
        >
      </div>

      <div class="ai-bulk-sales-form__field-{{ ai_gen_id }}">
        <label class="ai-bulk-sales-form__label-{{ ai_gen_id }}" for="contact-email-{{ ai_gen_id }}">
          {{ block.settings.email_label }} *
        </label>
        <input
          type="email"
          id="contact-email-{{ ai_gen_id }}"
          name="contact[email]"
          class="ai-bulk-sales-form__input-{{ ai_gen_id }}"
          required
          aria-required="true"
          autocomplete="email"
        >
      </div>

      <div class="ai-bulk-sales-form__field-{{ ai_gen_id }}">
        <label class="ai-bulk-sales-form__label-{{ ai_gen_id }}" for="contact-phone-{{ ai_gen_id }}">
          {{ block.settings.phone_label }} *
        </label>
        <input
          type="tel"
          id="contact-phone-{{ ai_gen_id }}"
          name="contact[Phone]"
          class="ai-bulk-sales-form__input-{{ ai_gen_id }}"
          required
          aria-required="true"
          autocomplete="tel"
        >
      </div>

      <div class="ai-bulk-sales-form__field-{{ ai_gen_id }}">
        <label class="ai-bulk-sales-form__label-{{ ai_gen_id }}" for="contact-book-{{ ai_gen_id }}">
          {{ block.settings.book_label }} *
        </label>
        <select
          id="contact-book-{{ ai_gen_id }}"
          name="contact[Book Title]"
          class="ai-bulk-sales-form__select-{{ ai_gen_id }}"
          required
          aria-required="true"
        >
          <option value="">{{ block.settings.book_placeholder }}</option>
          {% if block.settings.books_collection != blank %}
            {% paginate block.settings.books_collection.products by 250 %}
              {% for product in block.settings.books_collection.products %}
                {% if product.available %}
                  <option value="{{ product.title }}">{{ product.title }}</option>
                {% endif %}
              {% endfor %}
            {% endpaginate %}
          {% endif %}
        </select>
      </div>

      <div class="ai-bulk-sales-form__field-{{ ai_gen_id }}">
        <label class="ai-bulk-sales-form__label-{{ ai_gen_id }}" for="contact-quantity-{{ ai_gen_id }}">
          {{ block.settings.quantity_label }} *
        </label>
        <input
          type="number"
          id="contact-quantity-{{ ai_gen_id }}"
          name="contact[Quantity]"
          class="ai-bulk-sales-form__input-{{ ai_gen_id }}"
          min="1"
          required
          aria-required="true"
        >
      </div>

      <div class="ai-bulk-sales-form__field-{{ ai_gen_id }}">
        <label class="ai-bulk-sales-form__label-{{ ai_gen_id }}" for="contact-notes-{{ ai_gen_id }}">
          {{ block.settings.notes_label }}
        </label>
        <textarea
          id="contact-notes-{{ ai_gen_id }}"
          name="contact[Notes]"
          class="ai-bulk-sales-form__textarea-{{ ai_gen_id }}"
        ></textarea>
      </div>

      <button type="submit" class="ai-bulk-sales-form__button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </button>
    </div>
  {% endform %}
</bulk-sales-form-{{ ai_gen_id }}>

<script>
  (function() {
    class BulkSalesForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.form = this.querySelector('form');
        if (this.form) {
          this.form.addEventListener('submit', this.handleSubmit.bind(this));
        }
      }

      handleSubmit(event) {
        const nameInput = this.form.querySelector('input[name="contact[name]"]');
        const companyInput = this.form.querySelector('input[name="contact[Company]"]');
        const phoneInput = this.form.querySelector('input[name="contact[Phone]"]');
        const quantityInput = this.form.querySelector('input[name="contact[Quantity]"]');
        const notesInput = this.form.querySelector('textarea[name="contact[Notes]"]');

        const name = nameInput.value.trim();
        const company = companyInput.value.trim();
        const phone = phoneInput.value.trim();
        const quantity = quantityInput.value.trim();
        const notes = notesInput.value.trim();

        const nameRegex = /^[A-Za-z\s]+$/;
        const companyRegex = /^[A-Za-z\s]*$/;
        const phoneRegex = /^[0-9]+$/;
        const quantityRegex = /^[0-9]+$/;
        const notesRegex = /^[A-Za-z0-9\s.,-]*$/;

        if (!nameRegex.test(name)) {
          alert('Name should contain letters only.');
          event.preventDefault();
          return;
        }

        if (company && !companyRegex.test(company)) {
          alert('Company name should contain letters only.');
          event.preventDefault();
          return;
        }

        if (!phoneRegex.test(phone)) {
          alert('Phone number should contain numbers only.');
          event.preventDefault();
          return;
        }

        if (!quantityRegex.test(quantity)) {
          alert('Quantity should contain numbers only.');
          event.preventDefault();
          return;
        }

        if (notes && !notesRegex.test(notes)) {
          alert('Notes can contain only letters and numbers.');
          event.preventDefault();
          return;
        }
      }
    }

    customElements.define('bulk-sales-form-{{ ai_gen_id }}', BulkSalesForm{{ ai_gen_id }});
  })();
</script>

