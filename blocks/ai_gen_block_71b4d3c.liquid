{% doc %}
  @prompt
    SCROLL EFFECTS:
    
    * Fixed image while scrolling
    * Smooth parallax movement
    * Slight zoom effect on background
    * Fade-in text animation
    * Luxury cinematic scrolling feel
    
    SLIDER CONTROLS:
    
    * Minimal elegant arrows
    * Small black/gold navigation icons
    * Positioned center-bottom
    * Smooth hover transitions
    
    SHOPIFY REQUIREMENTS:
    
    * Build as editable Shopify section
    * Liquid schema support
    * Editable testimonials
    * Editable background image
    * Adjustable overlay opacity
    * Toggle parallax on/off
    * Fully responsive
    
    CUSTOM CSS:
    
    * background-size: cover
    * background-position: center
    * background-attachment: fixed
    * padding: 60px 55px
    * mobile padding: 20px
    * max-width container
    * maintain image clarity and visibility
    
    STYLE REFERENCE:
    Luxury fashion campaign, cinematic jewelry editorial, Vogue-style testimonial section, premium boutique homepage with visible luxury photography.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonial-slider-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-testimonial-slider__background-{{ ai_gen_id }} {
    position: relative;
    background-size: cover;
    background-position: center;
    {% if block.settings.enable_parallax %}
      background-attachment: fixed;
    {% endif %}
    padding: 60px 55px;
    min-height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  {% if block.settings.background_image %}
    .ai-testimonial-slider__background-{{ ai_gen_id }} {
      background-image: url('{{ block.settings.background_image | image_url: width: 2000 }}');
    }
  {% endif %}

  .ai-testimonial-slider__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    pointer-events: none;
  }

  .ai-testimonial-slider__container-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    max-width: {{ block.settings.content_max_width }}px;
    width: 100%;
    margin: 0 auto;
  }

  .ai-testimonial-slider__slides-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-testimonial-slider__slide-{{ ai_gen_id }} {
    opacity: 0;
    visibility: hidden;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    transition: opacity 0.8s ease, visibility 0.8s ease;
    text-align: center;
  }

  .ai-testimonial-slider__slide-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
    position: relative;
  }

  .ai-testimonial-slider__quote-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.quote_font_size }}px;
    line-height: 1.6;
    margin-bottom: 30px;
    font-style: italic;
  }

  .ai-testimonial-slider__author-{{ ai_gen_id }} {
    color: {{ block.settings.author_color }};
    font-size: {{ block.settings.author_font_size }}px;
    font-weight: 600;
    margin-bottom: 5px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .ai-testimonial-slider__role-{{ ai_gen_id }} {
    color: {{ block.settings.role_color }};
    font-size: {{ block.settings.role_font_size }}px;
    opacity: 0.8;
  }

  .ai-testimonial-slider__controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-top: 40px;
  }

  .ai-testimonial-slider__arrow-{{ ai_gen_id }} {
    width: 40px;
    height: 40px;
    border: 1px solid {{ block.settings.arrow_color }};
    background-color: transparent;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    border-radius: 50%;
  }

  .ai-testimonial-slider__arrow-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_hover_bg }};
    border-color: {{ block.settings.arrow_hover_bg }};
  }

  .ai-testimonial-slider__arrow-{{ ai_gen_id }} svg {
    width: 16px;
    height: 16px;
    stroke: {{ block.settings.arrow_color }};
    transition: stroke 0.3s ease;
  }

  .ai-testimonial-slider__arrow-{{ ai_gen_id }}:hover svg {
    stroke: {{ block.settings.arrow_hover_color }};
  }

  .ai-testimonial-slider__dots-{{ ai_gen_id }} {
    display: flex;
    gap: 10px;
  }

  .ai-testimonial-slider__dot-{{ ai_gen_id }} {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.4;
    cursor: pointer;
    transition: all 0.3s ease;
    border: none;
    padding: 0;
  }

  .ai-testimonial-slider__dot-{{ ai_gen_id }}.active {
    opacity: 1;
    background-color: {{ block.settings.dot_active_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-testimonial-slider__background-{{ ai_gen_id }} {
      padding: 40px 20px;
      min-height: 400px;
      {% if block.settings.enable_parallax %}
        background-attachment: scroll;
      {% endif %}
    }

    .ai-testimonial-slider__quote-{{ ai_gen_id }} {
      font-size: {{ block.settings.quote_font_size | times: 0.8 }}px;
    }

    .ai-testimonial-slider__author-{{ ai_gen_id }} {
      font-size: {{ block.settings.author_font_size | times: 0.9 }}px;
    }

    .ai-testimonial-slider__role-{{ ai_gen_id }} {
      font-size: {{ block.settings.role_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<luxury-testimonial-slider-{{ ai_gen_id }}
  class="ai-testimonial-slider-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-testimonial-slider__background-{{ ai_gen_id }}">
    <div class="ai-testimonial-slider__overlay-{{ ai_gen_id }}"></div>
    
    <div class="ai-testimonial-slider__container-{{ ai_gen_id }}">
      <div class="ai-testimonial-slider__slides-{{ ai_gen_id }}">
        {% for i in (1..5) %}
          {% liquid
            assign quote_key = 'testimonial_' | append: i | append: '_quote'
            assign author_key = 'testimonial_' | append: i | append: '_author'
            assign role_key = 'testimonial_' | append: i | append: '_role'
            
            assign quote = block.settings[quote_key]
            assign author = block.settings[author_key]
            assign role = block.settings[role_key]
          %}
          
          {% if quote != blank or author != blank %}
            <div class="ai-testimonial-slider__slide-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" data-slide="{{ forloop.index0 }}">
              {% if quote != blank %}
                <div class="ai-testimonial-slider__quote-{{ ai_gen_id }}">
                  {{ quote }}
                </div>
              {% endif %}
              
              {% if author != blank %}
                <div class="ai-testimonial-slider__author-{{ ai_gen_id }}">
                  {{ author }}
                </div>
              {% endif %}
              
              {% if role != blank %}
                <div class="ai-testimonial-slider__role-{{ ai_gen_id }}">
                  {{ role }}
                </div>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <div class="ai-testimonial-slider__controls-{{ ai_gen_id }}">
        <button class="ai-testimonial-slider__arrow-{{ ai_gen_id }} ai-testimonial-slider__prev-{{ ai_gen_id }}" aria-label="Previous testimonial">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>

        <div class="ai-testimonial-slider__dots-{{ ai_gen_id }}">
          {% for i in (1..5) %}
            {% liquid
              assign quote_key = 'testimonial_' | append: i | append: '_quote'
              assign author_key = 'testimonial_' | append: i | append: '_author'
              
              assign quote = block.settings[quote_key]
              assign author = block.settings[author_key]
            %}
            
            {% if quote != blank or author != blank %}
              <button class="ai-testimonial-slider__dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="Go to testimonial {{ forloop.index }}"></button>
            {% endif %}
          {% endfor %}
        </div>

        <button class="ai-testimonial-slider__arrow-{{ ai_gen_id }} ai-testimonial-slider__next-{{ ai_gen_id }}" aria-label="Next testimonial">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>
    </div>
  </div>
</luxury-testimonial-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class LuxuryTestimonialSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.slides = [];
        this.dots = [];
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.slides = Array.from(this.querySelectorAll('.ai-testimonial-slider__slide-{{ ai_gen_id }}'));
        this.dots = Array.from(this.querySelectorAll('.ai-testimonial-slider__dot-{{ ai_gen_id }}'));
        this.prevBtn = this.querySelector('.ai-testimonial-slider__prev-{{ ai_gen_id }}');
        this.nextBtn = this.querySelector('.ai-testimonial-slider__next-{{ ai_gen_id }}');

        if (this.slides.length === 0) return;

        this.setupEventListeners();
        {% if block.settings.enable_autoplay %}
          this.startAutoplay();
        {% endif %}
      }

      setupEventListeners() {
        this.prevBtn.addEventListener('click', () => this.goToPrevSlide());
        this.nextBtn.addEventListener('click', () => this.goToNextSlide());

        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => this.goToSlide(index));
        });
      }

      goToSlide(index) {
        this.slides[this.currentSlide].classList.remove('active');
        this.dots[this.currentSlide].classList.remove('active');

        this.currentSlide = index;

        this.slides[this.currentSlide].classList.add('active');
        this.dots[this.currentSlide].classList.add('active');

        {% if block.settings.enable_autoplay %}
          this.resetAutoplay();
        {% endif %}
      }

      goToNextSlide() {
        const nextIndex = (this.currentSlide + 1) % this.slides.length;
        this.goToSlide(nextIndex);
      }

      goToPrevSlide() {
        const prevIndex = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.goToSlide(prevIndex);
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          this.goToNextSlide();
        }, {{ block.settings.autoplay_speed }} * 1000);
      }

      resetAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.startAutoplay();
        }
      }

      disconnectedCallback() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
        }
      }
    }

    customElements.define('luxury-testimonial-slider-{{ ai_gen_id }}', LuxuryTestimonialSlider{{ ai_gen_id }});
  })();
</script>

