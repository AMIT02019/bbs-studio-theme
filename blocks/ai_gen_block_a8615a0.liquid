{% doc %}
  @prompt
    🔹 1️⃣ Replace Current Blog Header HTML With This
    <div class="blog-section-header">
      <h2 class="blog-section-title">
        {{ section.settings.blog_section_title }}
      </h2>
    
      <a href="{{ blogs[section.settings.blog].url }}" class="blog-view-all-btn">
        {{ section.settings.view_all_label }}
      </a>
    </div>
    
    
    Remove any centered title layout.
    
    🔹 2️⃣ Add These Schema Settings
    
    Add inside "settings":
    
    {
      "type": "text",
      "id": "blog_section_title",
      "label": "Section Title",
      "default": "BLOGS"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View All Button Text",
      "default": "VIEW ALL"
    }
    
    🔹 3️⃣ Add Header Styling
    .blog-section-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 30px;
    }
    
    .blog-section-title {
      margin: 0;
      font-size: 22px;
      font-weight: 700;
      text-transform: uppercase;
    }
    
    .blog-view-all-btn {
      padding: 8px 18px;
      border: 2px solid #0066cc;
      color: #0066cc;
      text-decoration: none;
      font-weight: 600;
      text-transform: uppercase;
      border-radius: 4px;
      transition: 0.3s ease;
    }
    
    .blog-view-all-btn:hover {
      background-color: #0066cc;
      color: #ffffff;
    }
    
    🔹 4️⃣ Make It Responsive
    @media (max-width: 768px) {
      .blog-section-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
      }
    }
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-blog-section-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-blog-section-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
  }

  .ai-blog-section-title-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: {{ block.settings.title_font_weight }};
    text-transform: uppercase;
    color: {{ block.settings.title_color }};
  }

  .ai-blog-view-all-btn-{{ ai_gen_id }} {
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    color: {{ block.settings.button_text_color }};
    background-color: {{ block.settings.button_bg_color }};
    text-decoration: none;
    font-weight: {{ block.settings.button_font_weight }};
    font-size: {{ block.settings.button_font_size }}px;
    text-transform: uppercase;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: all 0.3s ease;
    display: inline-block;
  }

  .ai-blog-view-all-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media (max-width: 768px) {
    .ai-blog-section-header-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }

    .ai-blog-section-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-blog-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-blog-section-header-{{ ai_gen_id }}">
    <h2 class="ai-blog-section-title-{{ ai_gen_id }}">
      {{ block.settings.blog_section_title }}
    </h2>

    {% if block.settings.blog != blank %}
      <a href="{{ blogs[block.settings.blog].url }}" class="ai-blog-view-all-btn-{{ ai_gen_id }}">
        {{ block.settings.view_all_label }}
      </a>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Blog section header",
  "settings": [
    {
      "type": "header",
      "content": "Blog selection"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "header",
      "content": "Section title"
    },
    {
      "type": "text",
      "id": "blog_section_title",
      "label": "Section title",
      "default": "BLOGS"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Title font size",
      "min": 14,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 22
    },
    {
      "type": "select",
      "id": "title_font_weight",
      "label": "Title font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        },
        {
          "value": "800",
          "label": "Extra bold"
        }
      ],
      "default": "700"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "View all button"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "Button text",
      "default": "VIEW ALL"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Font size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "button_font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "600"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#0066cc"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Background color",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Border color",
      "default": "#0066cc"
    },
    {
      "type": "range",
      "id": "button_border_width",
      "label": "Border width",
      "min": 0,
      "max": 5,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "button_padding_vertical",
      "label": "Vertical padding",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "button_padding_horizontal",
      "label": "Horizontal padding",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "header",
      "content": "Button hover state"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Hover text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "Hover background color",
      "default": "#0066cc"
    },
    {
      "type": "color",
      "id": "button_hover_border_color",
      "label": "Hover border color",
      "default": "#0066cc"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Blog section header"
    }
  ],
  "tag": null
}
{% endschema %}
