{% doc %}
  @prompt
    Create a luxury vintage banner/parallax section for a Shopify store inspired by editorial fashion campaigns and antique boutique aesthetics.
    
    SECTION STYLE:
    - Cinematic luxury vintage atmosphere
    - Warm golden lighting
    - Editorial museum-style visual
    - Antique illustration / vintage artwork aesthetic
    - Moody luxury shadows
    - Premium storytelling feel
    - Minimal and immersive design
    
    LAYOUT:
    - Full-width horizontal banner section
    - Large panoramic image
    - Edge-to-edge design
    - Responsive across all devices
    - Elegant visual focus with no clutter
    
    IMAGE STYLE:
    - Vintage illustration artwork
    - Warm beige and gold tones
    - Deep black ink sketch details
    - Renaissance / antique engraving aesthetic
    - Cinematic shadow overlays
    - High-detail texture
    - Luxury museum-like atmosphere
    
    BACKGROUND SETTINGS:
    Include a customizable “Background Attachment” setting with options:
    - Default
    - Scroll
    - Fixed (Parallax Effect)
    
    FEATURE REQUIREMENTS:
    - Add Shopify setting for:
      - Background image upload
      - Background attachment type
      - Overlay opacity
      - Section height
      - Background position
    - Allow switching between:
      1. default
      2. scroll
      3. fixed
    
    PARALLAX EFFECT:
    When “fixed” is selected:
    - Create smooth parallax scrolling effect
    - Background remains fixed while content scrolls
    - Cinematic immersive experience
    - Smooth performance optimized for desktop
    
    OVERLAY:
    - Optional dark transparent overlay
    - Adjustable opacity
    - Enhances luxury mood and readability
    
    HEIGHT OPTIONS:
    - Small banner
    - Medium banner
    - Full-screen hero
    - Custom height support
    
    DESIGN DETAILS:
    - Smooth transitions
    - High-quality responsive image rendering
    - Elegant luxury composition
    - No visible borders
    - Rich editorial aesthetic
    
    MOBILE OPTIMIZATION:
    - Disable fixed attachment on mobile for performance
    - Fallback to scroll on smaller screens
    - Maintain image quality and composition
    
    SHOPIFY REQUIREMENTS:
    - Build as customizable Shopify section
    - Compatible with Dawn theme
    - Editable via theme customizer
    - Fast-loading and optimized
    - Clean responsive code
    
    CSS FEATURE:
    Use:
    background-attachment: default | scroll | fixed;
    
    And dynamically change based on Shopify section settings.
    
    OVERALL GOAL:
    The section should feel like a premium cinematic luxury vintage fashion campaign with immersive parallax storytelling visuals inspired by antique galleries, editorial magazines, and high-end designer boutiques.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-vintage-parallax-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-vintage-parallax-banner__wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.section_height }}px;
    overflow: hidden;
  }

  .ai-vintage-parallax-banner__background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-repeat: no-repeat;
    background-position: {{ block.settings.background_position }};
    {% if block.settings.background_attachment == 'fixed' %}
      background-attachment: fixed;
    {% elsif block.settings.background_attachment == 'scroll' %}
      background-attachment: scroll;
    {% else %}
      background-attachment: initial;
    {% endif %}
    {% if block.settings.background_image %}
      background-image: url('{{ block.settings.background_image | image_url: width: 2400 }}');
    {% endif %}
  }

  .ai-vintage-parallax-banner__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #e8dcc8;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-vintage-parallax-banner__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 600px;
    max-height: 600px;
    opacity: 0.3;
  }

  .ai-vintage-parallax-banner__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    padding: 16px 32px;
    font-size: 16px;
    color: #8b7355;
    text-align: center;
    pointer-events: none;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 4px;
    font-weight: 500;
    letter-spacing: 0.5px;
  }

  .ai-vintage-parallax-banner__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, {{ block.settings.overlay_opacity }});
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-vintage-parallax-banner__background-{{ ai_gen_id }} {
      background-attachment: scroll !important;
    }

    .ai-vintage-parallax-banner__wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.section_height | times: 0.6 }}px;
    }

    .ai-vintage-parallax-banner__empty-state-{{ ai_gen_id }} {
      font-size: 14px;
      padding: 12px 24px;
      bottom: 20px;
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .ai-vintage-parallax-banner__wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.section_height | times: 0.8 }}px;
    }
  }
{% endstyle %}

<luxury-vintage-parallax-{{ ai_gen_id }}
  class="ai-vintage-parallax-banner-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-vintage-parallax-banner__wrapper-{{ ai_gen_id }}">
    {% if block.settings.background_image %}
      <div class="ai-vintage-parallax-banner__background-{{ ai_gen_id }}"></div>
    {% else %}
      <div class="ai-vintage-parallax-banner__placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-vintage-parallax-banner__empty-state-{{ ai_gen_id }}">
          Add a vintage luxury image to begin
        </div>
      </div>
    {% endif %}
    <div class="ai-vintage-parallax-banner__overlay-{{ ai_gen_id }}"></div>
  </div>
</luxury-vintage-parallax-{{ ai_gen_id }}>

<script>
  (function() {
    class LuxuryVintageParallax{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.backgroundElement = this.querySelector('.ai-vintage-parallax-banner__background-{{ ai_gen_id }}');
        
        if (this.backgroundElement && window.innerWidth > 749) {
          this.setupParallax();
        }
      }

      setupParallax() {
        const backgroundAttachment = this.backgroundElement.style.backgroundAttachment;
        
        if (backgroundAttachment === 'fixed') {
          this.handleScroll = this.handleScroll.bind(this);
          window.addEventListener('scroll', this.handleScroll, { passive: true });
        }
      }

      handleScroll() {
        if (!this.backgroundElement) return;
        
        const rect = this.getBoundingClientRect();
        const scrolled = window.pageYOffset;
        const rate = scrolled * 0.5;
        
        if (rect.top < window.innerHeight && rect.bottom > 0) {
          this.backgroundElement.style.transform = `translateY(${rate}px)`;
        }
      }

      disconnectedCallback() {
        if (this.handleScroll) {
          window.removeEventListener('scroll', this.handleScroll);
        }
      }
    }

    customElements.define('luxury-vintage-parallax-{{ ai_gen_id }}', LuxuryVintageParallax{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Luxury vintage parallax",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Background image"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "background_position",
      "label": "Image position",
      "options": [
        {
          "value": "center center",
          "label": "Center"
        },
        {
          "value": "top center",
          "label": "Top"
        },
        {
          "value": "bottom center",
          "label": "Bottom"
        },
        {
          "value": "left center",
          "label": "Left"
        },
        {
          "value": "right center",
          "label": "Right"
        }
      ],
      "default": "center center"
    },
    {
      "type": "select",
      "id": "background_attachment",
      "label": "Background attachment",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "scroll",
          "label": "Scroll"
        },
        {
          "value": "fixed",
          "label": "Fixed (Parallax)"
        }
      ],
      "default": "fixed",
      "info": "Parallax effect is disabled on mobile for performance"
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.3
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Desktop height",
      "min": 300,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "default": 600,
      "info": "Mobile height is automatically adjusted"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Luxury vintage parallax"
    }
  ]
}
{% endschema %}
