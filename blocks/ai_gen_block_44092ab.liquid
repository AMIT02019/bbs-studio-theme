{% doc %}
  @prompt
    create a collection list i want to call all the authores in one row i want four crds in this card first i wnt image and then name about author and them view all books button, no i have one specific collection i want to call the collection so all the collection wil automeacaly come i don't want to manualy  select the collection each time.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-author-list-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 20px;
  }

  .ai-author-list__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-author-list__heading-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
  }

  .ai-author-list__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.card_spacing }}px;
  }

  .ai-author-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_bg_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: 1px solid {{ block.settings.card_border_color }};
  }

  .ai-author-card-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .ai-author-card__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    margin-bottom: {{ block.settings.image_spacing }}px;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-author-card__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
  }

  .ai-author-card__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-author-card__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-author-card__name-{{ ai_gen_id }} {
    font-size: {{ block.settings.name_size }}px;
    font-weight: {{ block.settings.name_weight }};
    color: {{ block.settings.name_color }};
    margin: 0 0 {{ block.settings.name_spacing }}px;
  }

  .ai-author-card__about-{{ ai_gen_id }} {
    font-size: {{ block.settings.about_size }}px;
    color: {{ block.settings.about_color }};
    margin: 0 0 {{ block.settings.about_spacing }}px;
    line-height: 1.5;
  }

  .ai-author-card__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_size }}px;
    font-weight: {{ block.settings.button_weight }};
    transition: background-color 0.3s ease, color 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-author-card__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_bg_hover_color }};
    color: {{ block.settings.button_text_hover_color }};
  }

  .ai-author-list__empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666666;
    font-size: 16px;
  }

  @media screen and (max-width: 989px) {
    .ai-author-list__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-author-list__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<author-list-{{ ai_gen_id }} class="ai-author-list-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-author-list__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-author-list__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if block.settings.author_collections != blank %}
      <div class="ai-author-list__grid-{{ ai_gen_id }}">
        {% for collection in block.settings.author_collections limit: block.settings.collections_limit %}
          <div class="ai-author-card-{{ ai_gen_id }}">
            <div class="ai-author-card__image-wrapper-{{ ai_gen_id }}">
              {% if collection.image %}
                <img
                  src="{{ collection.image | image_url: width: 400 }}"
                  alt="{{ collection.title | escape }}"
                  class="ai-author-card__image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="400"
                  height="400"
                >
              {% else %}
                <div class="ai-author-card__image-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            <h3 class="ai-author-card__name-{{ ai_gen_id }}">{{ collection.title }}</h3>
            
            {% if collection.description != blank %}
              <div class="ai-author-card__about-{{ ai_gen_id }}">
                {{ collection.description | strip_html | truncate: 100 }}
              </div>
            {% else %}
              <div class="ai-author-card__about-{{ ai_gen_id }}">
                {{ block.settings.default_about_text }}
              </div>
            {% endif %}

            <a href="{{ collection.url }}" class="ai-author-card__button-{{ ai_gen_id }}">
              {{ block.settings.button_text }}
            </a>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="ai-author-list__empty-{{ ai_gen_id }}">
        Select a collection list to display authors
      </div>
    {% endif %}
  </div>
</author-list-{{ ai_gen_id }}>

<script>
  (function() {
    class AuthorList{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('author-list-{{ ai_gen_id }}', AuthorList{{ ai_gen_id }});
  })();
</script>

