{% doc %}
  @prompt
    🧱 Layout Structure
    1️⃣ Top Section (Centered Intro Block)
    
    Page title (e.g., “Find Store Location Near You”)
    
    Short description text
    
    Optional button (e.g., “Find a Store”)
    
    Centered layout
    Max width: 900px
    Text aligned center
    
    2️⃣ Full Width Google Map Section (Like Screenshot)
    
    Map must stretch 100% width
    
    No container padding on sides
    
    Height adjustable (default 450px)
    
    Responsive
    
    No rounded corners
    
    No card background
    
    Edge-to-edge layout
    
    🧩 Section Settings (Schema)
    Content Settings:
    
    Page Title (text)
    
    Description (rich text)
    
    Button Label (text)
    
    Button Link (url)
    
    Google Map Embed Code (textarea – paste iframe)
    
    Enable Button (checkbox)
    
    Map Settings:
    
    Map Height (range 300–700px)
    
    Full Width Toggle (checkbox)
    
    Remove Container Padding (checkbox)
    
    Spacing Controls:
    
    Section Padding Top (0–150px)
    
    Section Padding Bottom (0–150px)
    
    Title Margin Bottom (0–60px)
    
    🛠 Technical Requirements
    
    If full-width enabled:
    
    Override theme container
    
    Use:
    
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    
    
    Map must be:
    
    width: 100%
    
    height: dynamic from slider
    
    Fully responsive
    
    Clean Liquid structure
    
    No external JS required
    
    🔥 Important Difference From Previous Version
    
    ❌ Old version → Map inside right column
    ✅ New version → Map full width like your screenshot
    
    If you want, I can now generate the exact Liquid code for your Ella theme so you can paste it directly into your Contact template.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-store-locator-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-store-locator-intro-{{ ai_gen_id }} {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
    padding-top: {{ block.settings.section_padding_top }}px;
    padding-bottom: {{ block.settings.title_margin_bottom }}px;
  }

  .ai-store-locator-title-{{ ai_gen_id }} {
    margin: 0 0 16px;
    font-size: 32px;
    font-weight: 600;
    color: #000000;
  }

  .ai-store-locator-description-{{ ai_gen_id }} {
    margin: 0 0 24px;
    font-size: 16px;
    line-height: 1.6;
    color: #666666;
  }

  .ai-store-locator-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 32px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
    transition: background-color 0.3s ease;
  }

  .ai-store-locator-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
  }

  .ai-store-locator-map-wrapper-{{ ai_gen_id }} {
    {% if block.settings.full_width %}
      width: 100%;
      margin-left: calc(-50vw + 50%);
    {% else %}
      width: 100%;
    {% endif %}
    height: {{ block.settings.map_height }}px;
    padding-bottom: {{ block.settings.section_padding_bottom }}px;
  }

  .ai-store-locator-map-container-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    position: relative;
  }

  .ai-store-locator-map-container-{{ ai_gen_id }} iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  .ai-store-locator-map-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 16px;
    color: #999999;
  }

  .ai-store-locator-map-placeholder-{{ ai_gen_id }} svg {
    width: 80px;
    height: 80px;
    opacity: 0.5;
  }

  @media screen and (max-width: 749px) {
    .ai-store-locator-title-{{ ai_gen_id }} {
      font-size: 24px;
    }

    .ai-store-locator-description-{{ ai_gen_id }} {
      font-size: 14px;
    }

    .ai-store-locator-map-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.map_height | times: 0.7 }}px;
    }
  }
{% endstyle %}

<div class="ai-store-locator-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-store-locator-intro-{{ ai_gen_id }}">
    {% if block.settings.page_title != blank %}
      <h1 class="ai-store-locator-title-{{ ai_gen_id }}">{{ block.settings.page_title }}</h1>
    {% endif %}

    {% if block.settings.description != blank %}
      <div class="ai-store-locator-description-{{ ai_gen_id }}">
        {{ block.settings.description }}
      </div>
    {% endif %}

    {% if block.settings.enable_button and block.settings.button_label != blank %}
      <a href="{{ block.settings.button_link }}" class="ai-store-locator-button-{{ ai_gen_id }}">
        {{ block.settings.button_label }}
      </a>
    {% endif %}
  </div>

  <div class="ai-store-locator-map-wrapper-{{ ai_gen_id }}">
    <div class="ai-store-locator-map-container-{{ ai_gen_id }}">
      {% if block.settings.map_embed_code != blank %}
        {{ block.settings.map_embed_code }}
      {% else %}
        <div class="ai-store-locator-map-placeholder-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
          <p>Add your Google Map embed code in the block settings</p>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Store locator",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "page_title",
      "label": "Page title",
      "default": "Find Store Location Near You"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Visit our stores to experience our products in person and get expert advice from our team.</p>"
    },
    {
      "type": "checkbox",
      "id": "enable_button",
      "label": "Enable button",
      "default": true
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Find a Store"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Map settings"
    },
    {
      "type": "html",
      "id": "map_embed_code",
      "label": "Google Map embed code"
    },
    {
      "type": "range",
      "id": "map_height",
      "label": "Map height",
      "min": 300,
      "max": 700,
      "step": 10,
      "unit": "px",
      "default": 450
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width map",
      "default": true
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "Hover background",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Section padding top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Section padding bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "title_margin_bottom",
      "label": "Title margin bottom",
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Store locator"
    }
  ]
}
{% endschema %}
