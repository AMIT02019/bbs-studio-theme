{% doc %}
  @prompt
    Create a premium full-width Shopify testimonial section with a clearly visible luxury background image and cinematic fashion editorial style.
    
    IMPORTANT:
    
    * Background image must stay clearly visible
    * Do NOT make the overlay too dark
    * Maintain sharp visibility of luxury product image
    * Use only a soft black transparent overlay (20%–30%)
    * Keep the image bright, premium, and visually dominant
    
    SECTION DESIGN:
    
    * Full-width testimonial slider section
    * Height around 650px
    * Background image fixed during scroll
    * background-attachment: fixed
    * Smooth parallax scrolling effect
    * Cinematic luxury boutique aesthetic
    * High-end jewelry/fashion editorial vibe
    
    BACKGROUND IMAGE:
    
    * Large luxury fashion image clearly visible
    * Close-up premium accessory photography
    * Gold metallic details
    * Leather straps and luxury textures
    * Soft cinematic blur in background only
    * Warm gold and dark olive tones
    * Premium editorial lighting
    * Image should remain crisp and visible behind testimonials
    
    OVERLAY:
    
    * Very light dark overlay
    * rgba(0,0,0,0.25)
    * Preserve image visibility
    * Add subtle vignette only around edges
    
    LAYOUT:
    
    * Centered content
    * Heading at top center
    * Two testimonials side-by-side
    * Large spacing between testimonials
    * Content vertically centered
    * Clean luxury spacing
    * 55px left/right desktop padding
    * Mobile responsive
    
    HEADING:
    “WHAT OUR CUSTOMER SAY”
    
    HEADING STYLE:
    
    * White uppercase text
    * Luxury bold typography
    * Elegant underline below heading
    * Editorial premium fashion style
    
    TESTIMONIAL STYLE:
    
    * Transparent testimonial cards
    * White italic review text
    * Gold 5-star icons
    * Bold uppercase customer names
    * Soft fade-in animation
    * Elegant typography spacing
    
    LEFT REVIEW:
    ★★★★★
    “The best most authentic store for antiques and art in the city. I love the curation and I trust them blindly. A must visit!”
    — NITYA ARORA
    
    RIGHT REVIEW:
    ★★★★★
    “An outstanding immaculate amalgamation of clothing and accessories beyond my imagination. Just what we need for styling with an edge!”
    — ANKUR GULATI
    
    SCROLL EFFECTS:
    
    * Fixed image while scrolling
    * Smooth parallax movement
    * Slight zoom effect on background
    * Fade-in text animation
    * Luxury cinematic scrolling feel
    
    SLIDER CONTROLS:
    
    * Minimal elegant arrows
    * Small black/gold navigation icons
    * Positioned center-bottom
    * Smooth hover transitions
    
    SHOPIFY REQUIREMENTS:
    
    * Build as editable Shopify section
    * Liquid schema support
    * Editable testimonials
    * Editable background image
    * Adjustable overlay opacity
    * Toggle parallax on/off
    * Fully responsive
    
    CUSTOM CSS:
    
    * background-size: cover
    * background-position: center
    * background-attachment: fixed
    * padding: 60px 55px
    * mobile padding: 20px
    * max-width container
    * maintain image clarity and visibility
    
    STYLE REFERENCE:
    Luxury fashion campaign, cinematic jewelry editorial, Vogue-style testimonial section, premium boutique homepage with visible luxury photography.
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-luxury-testimonials-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: {{ block.settings.section_height }}px;
    overflow: hidden;
    display: block;
  }

  .ai-luxury-testimonials-bg-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    {% if block.settings.enable_parallax %}
      background-attachment: fixed;
    {% endif %}
    z-index: 1;
  }

  .ai-luxury-testimonials-bg-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-luxury-testimonials-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: {{ block.settings.overlay_color }};
    z-index: 2;
  }

  .ai-luxury-testimonials-vignette-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(ellipse at center, transparent 0%, rgba(0,0,0,{{ block.settings.vignette_opacity }}) 100%);
    z-index: 3;
  }

  .ai-luxury-testimonials-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 4;
    padding: 60px {{ block.settings.desktop_padding }}px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: {{ block.settings.section_height }}px;
  }

  .ai-luxury-testimonials-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    letter-spacing: {{ block.settings.heading_letter_spacing }};
    text-transform: uppercase;
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px;
    text-align: center;
    position: relative;
    padding-bottom: 20px;
  }

  .ai-luxury-testimonials-heading-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: {{ block.settings.underline_width }}px;
    height: {{ block.settings.underline_height }}px;
    background-color: {{ block.settings.underline_color }};
  }

  .ai-luxury-testimonials-slider-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.max_content_width }}px;
    margin: 0 auto;
    position: relative;
  }

  .ai-luxury-testimonials-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.testimonial_gap }}px;
    opacity: 0;
  }

  .ai-luxury-testimonials-grid-{{ ai_gen_id }}.active {
    opacity: 1;
    transition: opacity 0.6s ease;
  }

  .ai-luxury-testimonial-card-{{ ai_gen_id }} {
    background: {{ block.settings.card_background }};
    padding: {{ block.settings.card_padding }}px;
    text-align: center;
    border-radius: {{ block.settings.card_border_radius }}px;
  }

  .ai-luxury-testimonial-stars-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 4px;
    margin-bottom: {{ block.settings.stars_margin_bottom }}px;
  }

  .ai-luxury-testimonial-star-{{ ai_gen_id }} {
    color: {{ block.settings.star_color }};
    font-size: {{ block.settings.star_size }}px;
  }

  .ai-luxury-testimonial-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    font-style: {{ block.settings.text_style }};
    line-height: {{ block.settings.text_line_height }};
    margin: 0 0 {{ block.settings.text_margin_bottom }}px;
  }

  .ai-luxury-testimonial-author-{{ ai_gen_id }} {
    color: {{ block.settings.author_color }};
    font-size: {{ block.settings.author_size }}px;
    font-weight: {{ block.settings.author_weight }};
    text-transform: uppercase;
    letter-spacing: {{ block.settings.author_letter_spacing }};
    margin: 0;
  }

  .ai-luxury-testimonials-controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-top: {{ block.settings.controls_margin_top }}px;
  }

  .ai-luxury-testimonials-arrow-{{ ai_gen_id }} {
    background: {{ block.settings.arrow_background }};
    border: {{ block.settings.arrow_border_width }}px solid {{ block.settings.arrow_border_color }};
    color: {{ block.settings.arrow_color }};
    width: {{ block.settings.arrow_size }}px;
    height: {{ block.settings.arrow_size }}px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-luxury-testimonials-arrow-{{ ai_gen_id }}:hover {
    background: {{ block.settings.arrow_hover_background }};
    color: {{ block.settings.arrow_hover_color }};
    border-color: {{ block.settings.arrow_hover_border_color }};
    transform: scale(1.1);
  }

  .ai-luxury-testimonials-arrow-{{ ai_gen_id }} svg {
    width: 16px;
    height: 16px;
  }

  .ai-luxury-testimonials-dots-{{ ai_gen_id }} {
    display: flex;
    gap: 10px;
  }

  .ai-luxury-testimonials-dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background: {{ block.settings.dot_color }};
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-luxury-testimonials-dot-{{ ai_gen_id }}.active {
    background: {{ block.settings.dot_active_color }};
    transform: scale(1.2);
  }

  @media screen and (max-width: 749px) {
    .ai-luxury-testimonials-content-{{ ai_gen_id }} {
      padding: 40px {{ block.settings.mobile_padding }}px;
      min-height: auto;
    }

    .ai-luxury-testimonials-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .ai-luxury-testimonials-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }

    .ai-luxury-testimonial-text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.text_size }}px * 0.9);
    }

    .ai-luxury-testimonials-bg-{{ ai_gen_id }} {
      background-attachment: scroll;
    }
  }
{% endstyle %}

<luxury-testimonials-{{ ai_gen_id }} class="ai-luxury-testimonials-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-luxury-testimonials-bg-{{ ai_gen_id }}" {% if block.settings.background_image %}style="background-image: url('{{ block.settings.background_image | image_url: width: 2000 }}');"{% endif %}>
    {% unless block.settings.background_image %}
      {{ 'hero-apparel-1' | placeholder_svg_tag }}
    {% endunless %}
  </div>
  
  <div class="ai-luxury-testimonials-overlay-{{ ai_gen_id }}"></div>
  <div class="ai-luxury-testimonials-vignette-{{ ai_gen_id }}"></div>

  <div class="ai-luxury-testimonials-content-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-luxury-testimonials-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-luxury-testimonials-slider-{{ ai_gen_id }}">
      <div class="ai-luxury-testimonials-grid-{{ ai_gen_id }} active" data-slide="0">
        {% for i in (1..2) %}
          {% liquid
            assign testimonial_text_key = 'testimonial_' | append: i | append: '_text'
            assign testimonial_author_key = 'testimonial_' | append: i | append: '_author'
            assign testimonial_rating_key = 'testimonial_' | append: i | append: '_rating'
            
            assign testimonial_text = block.settings[testimonial_text_key]
            assign testimonial_author = block.settings[testimonial_author_key]
            assign testimonial_rating = block.settings[testimonial_rating_key]
          %}
          
          <div class="ai-luxury-testimonial-card-{{ ai_gen_id }}">
            <div class="ai-luxury-testimonial-stars-{{ ai_gen_id }}">
              {% for star in (1..testimonial_rating) %}
                <span class="ai-luxury-testimonial-star-{{ ai_gen_id }}">★</span>
              {% endfor %}
            </div>
            
            {% if testimonial_text != blank %}
              <p class="ai-luxury-testimonial-text-{{ ai_gen_id }}">"{{ testimonial_text }}"</p>
            {% endif %}
            
            {% if testimonial_author != blank %}
              <p class="ai-luxury-testimonial-author-{{ ai_gen_id }}">— {{ testimonial_author }}</p>
            {% endif %}
          </div>
        {% endfor %}
      </div>

      {% if block.settings.testimonial_3_text != blank or block.settings.testimonial_4_text != blank %}
        <div class="ai-luxury-testimonials-grid-{{ ai_gen_id }}" data-slide="1" style="display: none;">
          {% for i in (3..4) %}
            {% liquid
              assign testimonial_text_key = 'testimonial_' | append: i | append: '_text'
              assign testimonial_author_key = 'testimonial_' | append: i | append: '_author'
              assign testimonial_rating_key = 'testimonial_' | append: i | append: '_rating'
              
              assign testimonial_text = block.settings[testimonial_text_key]
              assign testimonial_author = block.settings[testimonial_author_key]
              assign testimonial_rating = block.settings[testimonial_rating_key]
            %}
            
            {% if testimonial_text != blank %}
              <div class="ai-luxury-testimonial-card-{{ ai_gen_id }}">
                <div class="ai-luxury-testimonial-stars-{{ ai_gen_id }}">
                  {% for star in (1..testimonial_rating) %}
                    <span class="ai-luxury-testimonial-star-{{ ai_gen_id }}">★</span>
                  {% endfor %}
                </div>
                
                <p class="ai-luxury-testimonial-text-{{ ai_gen_id }}">"{{ testimonial_text }}"</p>
                
                {% if testimonial_author != blank %}
                  <p class="ai-luxury-testimonial-author-{{ ai_gen_id }}">— {{ testimonial_author }}</p>
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}

      {% if block.settings.show_controls %}
        <div class="ai-luxury-testimonials-controls-{{ ai_gen_id }}">
          <button class="ai-luxury-testimonials-arrow-{{ ai_gen_id }} ai-luxury-testimonials-prev-{{ ai_gen_id }}" aria-label="Previous testimonials">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
          </button>
          
          <div class="ai-luxury-testimonials-dots-{{ ai_gen_id }}">
            <span class="ai-luxury-testimonials-dot-{{ ai_gen_id }} active" data-slide="0"></span>
            {% if block.settings.testimonial_3_text != blank or block.settings.testimonial_4_text != blank %}
              <span class="ai-luxury-testimonials-dot-{{ ai_gen_id }}" data-slide="1"></span>
            {% endif %}
          </div>
          
          <button class="ai-luxury-testimonials-arrow-{{ ai_gen_id }} ai-luxury-testimonials-next-{{ ai_gen_id }}" aria-label="Next testimonials">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </button>
        </div>
      {% endif %}
    </div>
  </div>
</luxury-testimonials-{{ ai_gen_id }}>

<script>
  (function() {
    class LuxuryTestimonials{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.slides = [];
        this.dots = [];
      }

      connectedCallback() {
        this.slides = Array.from(this.querySelectorAll('.ai-luxury-testimonials-grid-{{ ai_gen_id }}'));
        this.dots = Array.from(this.querySelectorAll('.ai-luxury-testimonials-dot-{{ ai_gen_id }}'));
        
        const prevBtn = this.querySelector('.ai-luxury-testimonials-prev-{{ ai_gen_id }}');
        const nextBtn = this.querySelector('.ai-luxury-testimonials-next-{{ ai_gen_id }}');

        if (prevBtn) {
          prevBtn.addEventListener('click', () => this.prevSlide());
        }

        if (nextBtn) {
          nextBtn.addEventListener('click', () => this.nextSlide());
        }

        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => this.goToSlide(index));
        });

        this.showSlide(this.currentSlide);
      }

      showSlide(index) {
        this.slides.forEach((slide, i) => {
          if (i === index) {
            slide.style.display = 'grid';
            setTimeout(() => {
              slide.classList.add('active');
            }, 10);
          } else {
            slide.classList.remove('active');
            setTimeout(() => {
              slide.style.display = 'none';
            }, 600);
          }
        });

        this.dots.forEach((dot, i) => {
          if (i === index) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      nextSlide() {
        this.currentSlide = (this.currentSlide + 1) % this.slides.length;
        this.showSlide(this.currentSlide);
      }

      prevSlide() {
        this.currentSlide = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.showSlide(this.currentSlide);
      }

      goToSlide(index) {
        this.currentSlide = index;
        this.showSlide(this.currentSlide);
      }
    }

    customElements.define('luxury-testimonials-{{ ai_gen_id }}', LuxuryTestimonials{{ ai_gen_id }});
  })();
</script>

