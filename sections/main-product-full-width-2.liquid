{%- liquid
    assign current_variant   = product.selected_or_first_available_variant
    assign compare_price     = current_variant.compare_at_price
    assign sale_price        = current_variant.price
    assign vendor_handle     = product.vendor | handleize
    assign form_id           = 'ppf-' | append: section.id
    assign vendor_collection = collections[vendor_handle]
    assign cond_levels       = 'Fair,Good,Very Good,Excellent,New' | split: ','
    assign wa_number         = section.settings.wa_number   | default: '919136047270'
    assign coupon_code       = section.settings.coupon_code | default: 'MYFIRST'
    assign coupon_text       = section.settings.coupon_text | default: '₹2,000 off on your first order above ₹25,000'
    assign sell_page         = section.settings.sell_page   | default: '/pages/sell-with-us'
    assign return_days       = section.settings.return_days | default: '7'
    assign wa_msg            = 'Hi! I am interested in ' | append: product.title | url_encode
    assign wa_msg_full       = 'Hi! I need more info about ' | append: product.title | append: ' - ' | append: shop.url | append: product.url | url_encode
  -%}

  {%- assign condition_label = '' -%}
  {%- for tag in product.tags -%}
    {%- if tag contains 'Condition:' -%}
      {%- assign condition_label = tag | remove: 'Condition:' | strip -%}
    {%- endif -%}
  {%- endfor -%}

  {%- assign current_cond_index = -1 -%}
  {%- for lvl in cond_levels -%}
    {%- if lvl == condition_label -%}
      {%- assign current_cond_index = forloop.index0 -%}
    {%- endif -%}
  {%- endfor -%}

  {%- assign show_sale    = false -%}
  {%- assign discount_pct = 0 -%}
  {%- if compare_price > sale_price -%}
    {%- assign show_sale   = true -%}
    {%- assign disc_amount = compare_price | minus: sale_price -%}
    {%- assign discount_pct = disc_amount | times: 100 | divided_by: compare_price -%}
  {%- endif -%}

  {%- assign product_images = product.media | where: 'media_type', 'image' -%}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">

  <style>
  #pp-{{ section.id }} *,
  #pp-{{ section.id }} *::before,
  #pp-{{ section.id }} *::after { box-sizing: border-box; }

  #pp-{{ section.id }} {
    background: #fff;
    color: #0a0a0a;
    font-family: 'Montserrat', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 15.36px;
    line-height: 1.6;
    width: 100%;
  }

  #pp-{{ section.id }} .pp-hero {
    display: flex;
    flex-direction: row;
    width: 100%;
    align-items: flex-start;
  }

  #pp-{{ section.id }} .pp-gallery {
    width: 50%;
    flex-shrink: 0;
    padding: 40px 24px 48px;
    align-self: flex-start;
    will-change: transform;
  }

  #pp-{{ section.id }} .pp-frame {
    aspect-ratio: 1 / 1;
    width: 80%;
    margin: 0 auto;
  }

  #pp-{{ section.id }} .pp-glass {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: #fff;
  }

  #pp-{{ section.id }} .pp-glass-border {
    position: absolute;
    inset: 0;
    border: 0.8px solid rgba(0,0,0,.07);
    z-index: 3;
    pointer-events: none;
  }

  #pp-{{ section.id }} .pp-viewport {
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  #pp-{{ section.id }} .pp-track {
    display: flex;
    width: 100%;
    height: 100%;
    transition: transform 0.42s cubic-bezier(.25,.46,.45,.94);
    will-change: transform;
  }

  #pp-{{ section.id }} .pp-slide {
    flex: 0 0 100%;
    height: 100%;
  }

  #pp-{{ section.id }} .pp-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    -webkit-user-drag: none;
    user-select: none;
  }

  #pp-{{ section.id }} .pp-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 4;
    background: rgba(255,255,255,.88);
    border: 0.8px solid rgba(0,0,0,.12);
    border-radius: 0;
    width: 38px;
    height: 38px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: background .15s;
  }
  #pp-{{ section.id }} .pp-nav:hover { background: #fff; }
  #pp-{{ section.id }} .pp-nav--prev { left: 10px; }
  #pp-{{ section.id }} .pp-nav--next { right: 10px; }

  #pp-{{ section.id }} .pp-zoom {
    position: absolute;
    bottom: 48px;
    right: 12px;
    z-index: 4;
    background: rgba(255,255,255,.88);
    border: 0.8px solid rgba(0,0,0,.12);
    width: 32px;
    height: 32px;
    border-radius: 0;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  #pp-{{ section.id }} .pp-controls {
    position: absolute;
    bottom: 22px;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 14px;
    z-index: 4;
  }
  #pp-{{ section.id }} .pp-counter {
    font-size: 11px;
    color: rgba(255,255,255,.85);
    letter-spacing: .5px;
    flex-shrink: 0;
    min-width: 28px;
    text-shadow: 0 1px 2px rgba(0,0,0,.4);
  }
  #pp-{{ section.id }} .pp-progress {
    flex: 1;
    height: 1px;
    background: rgba(255,255,255,.35);
    position: relative;
    overflow: hidden;
  }
  #pp-{{ section.id }} .pp-progress-fill {
    position: absolute;
    left: 0; top: 0; bottom: 0;
    background: #fff;
    transition: width .35s ease;
  }

  #pp-{{ section.id }} .pp-dots {
    position: absolute;
    bottom: 8px;
    left: 0;
    right: 0;
    display: flex;
    justify-content: center;
    gap: 5px;
    z-index: 4;
  }
  #pp-{{ section.id }} .pp-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: rgba(255,255,255,.5);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background .2s, transform .2s;
  }
  #pp-{{ section.id }} .pp-dot.is-active {
    background: #fff;
    transform: scale(1.3);
  }

  #pp-{{ section.id }} .pp-info {
    flex: 0 0 50%;
    padding: 40px 52px 60px 48px;
    min-width: 0;
    max-width: 50%;
  }
  #pp-{{ section.id }} .pp-container { max-width: 640px; }

  #pp-{{ section.id }} .pp-brand {
    display: inline-flex;
    align-items: center;
    gap: 11.52px;
    text-decoration: none;
    color: #0a0a0a;
    margin-bottom: 15.36px;
  }
  #pp-{{ section.id }} .pp-brand__text {
    font-size: 11.52px;
    font-weight: 600;
    color: rgb(58,58,58);
    letter-spacing: 2.304px;
    text-transform: uppercase;
    line-height: 1;
  }
  #pp-{{ section.id }} .pp-brand__line {
    display: block;
    width: 1px;
    height: 11px;
    background: #d0d0d0;
  }

  #pp-{{ section.id }} .pp-title {
    font-family: 'Montserrat', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 38.4px;
    font-weight: 400;
    color: #0a0a0a;
    line-height: 46.08px;
    margin: 0 0 38.4px;
  }

  #pp-{{ section.id }} .pp-price-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 23.04px;
  }
  #pp-{{ section.id }} .pp-price { font-size: 22px; font-weight: 400; color: #0a0a0a; line-height: 1.4; }
  #pp-{{ section.id }} .pp-compare { font-size: 15.36px; color: #bbb; text-decoration: line-through; }
  #pp-{{ section.id }} .pp-save { font-size: 11px; background: #f2f2f2; color: #555; padding: 2px 7px; letter-spacing: .4px; font-weight: 500; }

  #pp-{{ section.id }} .pp-verified { margin-top: 23.04px; margin-bottom: 23.04px; }
  #pp-{{ section.id }} .pp-verified__badge {
    display: inline-flex;
    align-items: center;
    gap: 7.68px;
    border: 0.8px solid #0a0a0a;
    border-radius: 30.72px;
    padding: 7.68px 15.36px;
    background: #fff;
    font-size: 12px;
    font-weight: 500;
    color: #0a0a0a;
  }

  #pp-{{ section.id }} .pp-form-wrap { display: contents; }
  #pp-{{ section.id }} .pp-buy-stack { display: grid; gap: 11.52px; margin-bottom: 0; }

  #pp-{{ section.id }} .pp-atc {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #0a0a0a;
    color: #fff;
    border: 0.8px solid #0a0a0a;
    border-radius: 0;
    font-family: 'Montserrat', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 12.288px;
    font-weight: 600;
    padding: 12.288px 18.432px;
    height: 46.4375px;
    cursor: pointer;
    letter-spacing: .3px;
    transition: background .15s;
  }
  #pp-{{ section.id }} .pp-atc:hover { background: #222; border-color: #222; }
  #pp-{{ section.id }} .pp-atc:disabled { background: #999; border-color: #999; cursor: not-allowed; }

  #pp-{{ section.id }} .shopify-payment-button { margin: 0; }
  #pp-{{ section.id }} .shopify-payment-button__button {
    border-radius: 0 !important;
    height: 46.4375px !important;
    font-size: 12.288px !important;
    font-weight: 600 !important;
    padding: 0 18.432px !important;
    font-family: 'Montserrat', -apple-system, BlinkMacSystemFont, sans-serif !important;
  }
  #pp-{{ section.id }} .shopify-payment-button__button--unbranded {
    background: #fff !important;
    color: #0a0a0a !important;
    border: 0.8px solid #0a0a0a !important;
  }
  #pp-{{ section.id }} .shopify-payment-button__button--unbranded:hover { background: #f5f5f5 !important; }

  #pp-{{ section.id }} .pp-wish {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 7.68px;
    border: 0.8px solid #ddd;
    background: #fff;
    font-size: 12.288px;
    font-weight: 500;
    color: #0a0a0a;
    padding: 0 18px;
    height: 40px;
    cursor: pointer;
    border-radius: 0;
    font-family: 'Montserrat', -apple-system, BlinkMacSystemFont, sans-serif;
    transition: border-color .15s;
    margin-top: 8px;
  }
  #pp-{{ section.id }} .pp-wish:hover { border-color: #0a0a0a; }
  #pp-{{ section.id }} .pp-wish.is-active { color: #c0392b; border-color: #c0392b; }

  #pp-{{ section.id }} .pp-sku {
    display: block;
    font-size: 12.288px;
    color: rgb(58,58,58);
    margin-top: 20px;
  }

  #pp-{{ section.id }} .pp-concierge {
    display: flex;
    align-items: center;
    gap: 15.36px;
    padding: 15.36px 23.04px;
    margin-top: 24px;
    background: rgba(37,211,102,.05);
    text-decoration: none;
    color: rgb(42,42,42);
    font-size: 15.36px;
    transition: background .15s;
  }
  #pp-{{ section.id }} .pp-concierge:hover { background: rgba(37,211,102,.09); }

  #pp-{{ section.id }} .pp-sell {
    display: flex;
    align-items: center;
    gap: 12px;
    border: 0.8px solid #e5e5e5;
    padding: 15.36px 23.04px;
    text-decoration: none;
    color: rgb(42,42,42);
    margin-top: 20px;
    transition: border-color .15s;
  }
  #pp-{{ section.id }} .pp-sell:hover { border-color: #0a0a0a; }
  #pp-{{ section.id }} .pp-sell__title { font-size: 15.36px; font-weight: 400; }
  #pp-{{ section.id }} .pp-sell__sub { font-size: 12px; color: #888; text-decoration: underline; }

  #pp-{{ section.id }} .pp-cond { margin: 24px 0; }
  #pp-{{ section.id }} .pp-cond__hd {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }
  #pp-{{ section.id }} .pp-cond__label {
    font-size: 11px;
    font-weight: 600;
    color: #888;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  #pp-{{ section.id }} .pp-cond__more {
    font-size: 11px;
    color: #888;
    text-decoration: underline;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    padding: 0;
  }
  #pp-{{ section.id }} .pp-cond__bar { display: flex; }
  #pp-{{ section.id }} .pp-cond__step {
    flex: 1;
    padding: 5px 0 6px;
    text-align: center;
    font-size: 10px;
    font-weight: 500;
    color: #ccc;
    border-bottom: 1.5px solid #e8e8e8;
  }
  #pp-{{ section.id }} .pp-cond__step.is-past { color: #888; border-color: #888; }
  #pp-{{ section.id }} .pp-cond__step.is-active { color: #0a0a0a; border-color: #0a0a0a; font-weight: 700; }

  #pp-{{ section.id }} .pp-hr { border: none; border-top: 0.8px solid #e8e8e8; margin: 24px 0 0; }

  #pp-{{ section.id }} .pp-desc-btn {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 0;
    background: none;
    border: none;
    border-bottom: 0.8px solid #e8e8e8;
    cursor: pointer;
    font-family: 'Montserrat', -apple-system, BlinkMacSystemFont, sans-serif;
    color: #0a0a0a;
  }
  #pp-{{ section.id }} .pp-desc-btn__title {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  #pp-{{ section.id }} .pp-desc-btn__icon {
    width: 14px; height: 14px;
    color: #888;
    flex-shrink: 0;
    transition: transform .25s;
  }
  #pp-{{ section.id }} .pp-desc.is-open .pp-desc-btn__icon { transform: rotate(180deg); }
  #pp-{{ section.id }} .pp-desc__body { display: none; padding: 16px 0; }
  #pp-{{ section.id }} .pp-desc.is-open .pp-desc__body { display: block; }
  #pp-{{ section.id }} .pp-desc__text { font-size: 13px; color: #555; line-height: 1.75; }
  #pp-{{ section.id }} .pp-specs { width: 100%; border-collapse: collapse; font-size: 13px; margin-bottom: 12px; }
  #pp-{{ section.id }} .pp-specs tr { border-bottom: 0.8px solid #f0f0f0; }
  #pp-{{ section.id }} .pp-specs td { padding: 7px 4px; vertical-align: top; }
  #pp-{{ section.id }} .pp-specs td:first-child { color: #888; font-weight: 600; width: 38%; white-space: nowrap; }

  #pp-{{ section.id }} .pp-accordion { border-top: 0.8px solid #e5e5e5; }
  #pp-{{ section.id }} .pp-acc-item { border-bottom: 0.8px solid #e5e5e5; }
  #pp-{{ section.id }} .pp-acc-btn {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 18px 24px;
    background: none;
    border: none;
    cursor: pointer;
    font-family: 'Montserrat', -apple-system, BlinkMacSystemFont, sans-serif;
    text-align: left;
    transition: background .12s;
  }
  #pp-{{ section.id }} .pp-acc-btn:hover { background: #fafafa; }
  #pp-{{ section.id }} .pp-acc-title { font-size: 11px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; color: #0a0a0a; }
  #pp-{{ section.id }} .pp-acc-icon { width: 14px; height: 14px; color: #888; flex-shrink: 0; transition: transform .25s; }
  #pp-{{ section.id }} .pp-acc-item.is-open .pp-acc-icon { transform: rotate(180deg); }
  #pp-{{ section.id }} .pp-acc-body { display: none; padding: 0 24px 22px; font-size: 13px; color: #555; line-height: 1.75; }
  #pp-{{ section.id }} .pp-acc-item.is-open .pp-acc-body { display: block; }
  #pp-{{ section.id }} .pp-acc-body h3 { font-size: 12px; font-weight: 700; color: #0a0a0a; margin: 12px 0 5px; text-transform: uppercase; letter-spacing: .5px; }
  #pp-{{ section.id }} .pp-acc-body p { margin: 0 0 10px; }
  #pp-{{ section.id }} .pp-acc-body ul { padding-left: 18px; margin: 0 0 10px; }
  #pp-{{ section.id }} .pp-acc-body li { margin-bottom: 5px; }

  #pp-{{ section.id }} .pp-related { padding: 52px 60px 60px; }
  #pp-{{ section.id }} .pp-related__hd { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 28px; }
  #pp-{{ section.id }} .pp-related__title { font-family: 'Montserrat', -apple-system, BlinkMacSystemFont, sans-serif; font-size: 26px; font-weight: 400; color: #0a0a0a; }
  #pp-{{ section.id }} .pp-related__all { font-size: 12px; color: #888; text-decoration: underline; }
  #pp-{{ section.id }} .pp-rel-wrap { position: relative; }
  #pp-{{ section.id }} .pp-rel-overflow { overflow: hidden; }
  #pp-{{ section.id }} .pp-rel-track { display: flex; gap: 16px; transition: transform .35s ease; }
  #pp-{{ section.id }} .pp-rel-card { flex: 0 0 calc(25% - 12px); min-width: 0; text-decoration: none; color: inherit; display: block; }
  #pp-{{ section.id }} .pp-rel-img-wrap { aspect-ratio: 3/4; overflow: hidden; background: #f9f8f6; margin-bottom: 12px; }
  #pp-{{ section.id }} .pp-rel-img { width: 100%; height: 100%; object-fit: cover; display: block; transition: opacity .2s; }
  #pp-{{ section.id }} .pp-rel-card:hover .pp-rel-img { opacity: .85; }
  #pp-{{ section.id }} .pp-rel-vendor { font-size: 10px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; color: #aaa; margin-bottom: 4px; }
  #pp-{{ section.id }} .pp-rel-name { font-size: 13px; color: #0a0a0a; line-height: 1.4; margin-bottom: 5px; }
  #pp-{{ section.id }} .pp-rel-price { font-size: 13px; color: #0a0a0a; }
  #pp-{{ section.id }} .pp-rel-was { font-size: 12px; color: #bbb; text-decoration: line-through; margin-left: 5px; }
  #pp-{{ section.id }} .pp-rel-nav {
    position: absolute; top: 35%; transform: translateY(-50%);
    background: #fff; border: 0.8px solid #e0e0e0; border-radius: 0;
    width: 36px; height: 36px; cursor: pointer;
    display: flex; align-items: center; justify-content: center; z-index: 2;
  }
  #pp-{{ section.id }} .pp-rel-nav:hover { background: #f5f5f5; }
  #pp-{{ section.id }} .pp-rel-nav--prev { left: -18px; }
  #pp-{{ section.id }} .pp-rel-nav--next { right: -18px; }

  #pp-{{ section.id }} .pp-cond-modal {
    display: none; position: fixed; inset: 0;
    background: rgba(0,0,0,.45); z-index: 9999;
    align-items: center; justify-content: center;
  }
  #pp-{{ section.id }} .pp-cond-modal.is-open { display: flex; }
  #pp-{{ section.id }} .pp-modal {
    background: #fff; padding: 32px 28px; max-width: 420px;
    width: 92%; max-height: 80vh; overflow-y: auto; position: relative;
  }
  #pp-{{ section.id }} .pp-modal-close {
    position: absolute; top: 14px; right: 16px;
    background: none; border: none; font-size: 22px;
    cursor: pointer; color: #888; line-height: 1; padding: 0;
  }
  #pp-{{ section.id }} .pp-modal h2 {
    font-family: 'Montserrat', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 20px; font-weight: 400; margin: 0 0 20px; color: #0a0a0a;
  }
  #pp-{{ section.id }} .pp-modal-row { margin-bottom: 16px; padding-bottom: 16px; border-bottom: 0.8px solid #f0f0f0; }
  #pp-{{ section.id }} .pp-modal-row:last-child { border-bottom: none; margin-bottom: 0; }
  #pp-{{ section.id }} .pp-modal-row__name { font-size: 13px; font-weight: 700; color: #0a0a0a; margin-bottom: 3px; }
  #pp-{{ section.id }} .pp-modal-row__desc { font-size: 12px; color: #666; line-height: 1.6; }

  #pp-{{ section.id }} .pp-float-wa {
    position: fixed; bottom: 24px; right: 24px; z-index: 999;
    background: #25D366; border-radius: 50%;
    width: 52px; height: 52px;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 4px 16px rgba(0,0,0,.18);
    text-decoration: none;
    transition: transform .2s;
  }
  #pp-{{ section.id }} .pp-float-wa:hover { transform: scale(1.1); }

  /* ── SCROLL ANIMATIONS ── */
  #pp-{{ section.id }} .pp-anim {
    opacity: 0;
    transform: translateY(22px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }
  #pp-{{ section.id }} .pp-anim.is-visible { opacity: 1; transform: translateY(0); }
  #pp-{{ section.id }} .pp-anim-left {
    opacity: 0; transform: translateX(-24px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }
  #pp-{{ section.id }} .pp-anim-left.is-visible { opacity: 1; transform: translateX(0); }
  #pp-{{ section.id }} .pp-anim-scale {
    opacity: 0; transform: scale(0.96);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  #pp-{{ section.id }} .pp-anim-scale.is-visible { opacity: 1; transform: scale(1); }

  @media(max-width:900px) {
    #pp-{{ section.id }} .pp-hero { flex-direction: column; }
    #pp-{{ section.id }} .pp-gallery { width: 100%; padding: 20px 20px 24px; transform: none !important; }
    #pp-{{ section.id }} .pp-frame { width: 92%; }
    #pp-{{ section.id }} .pp-info { padding: 24px 24px 40px; max-width: 100%; flex: 0 0 100%; }
    #pp-{{ section.id }} .pp-related { padding: 32px 20px 40px; }
    #pp-{{ section.id }} .pp-rel-card { flex: 0 0 calc(50% - 8px); }
    #pp-{{ section.id }} .pp-title { font-size: 26px; line-height: 1.3; margin-bottom: 20px; }
  }
  @media(max-width:540px) {
