  </div>

  <script>
  (function () {
    var sid  = '{{ section.id }}';
    var root = document.getElementById('pp-' + sid);
    if (!root) return;

    /* ── JS STICKY (translateY — works even with overflow:hidden parents) ── */
    var gal  = document.getElementById('pp-gallery-' + sid);
    var hero = gal && gal.closest('.pp-hero');
    if (gal && hero && window.innerWidth > 900) {
      function hdrH() {
        var hg = document.querySelector('.shopify-section-group-header-group');
        if (hg) return hg.getBoundingClientRect().bottom + 8;
        var h = document.querySelector('header');
        if (h) return h.getBoundingClientRect().bottom + 8;
        return 80;
      }
      var ticking = false;
      function doSticky() {
        var T   = hdrH();
        var top = hero.getBoundingClientRect().top;
        var max = Math.max(0, hero.offsetHeight - gal.offsetHeight - 20);
        gal.style.transform = 'translateY(' + Math.max(0, Math.min(T - top, max)) + 'px)';
        ticking = false;
      }
      window.addEventListener('scroll', function () {
        if (!ticking) { requestAnimationFrame(doSticky); ticking = true; }
      }, { passive: true });
      window.addEventListener('resize', function () {
        if (window.innerWidth <= 900) { gal.style.transform = ''; }
        else { requestAnimationFrame(doSticky); }
      }, { passive: true });
      doSticky();
    }

    /* ── SCROLL ANIMATIONS ── */
    if ('IntersectionObserver' in window) {
      var animEls = root.querySelectorAll('.pp-anim, .pp-anim-left, .pp-anim-scale');
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.12 });
      animEls.forEach(function (el) { io.observe(el); });
    } else {
      root.querySelectorAll('.pp-anim, .pp-anim-left, .pp-anim-scale').forEach(function (el) {
        el.classList.add('is-visible');
      });
    }

    /* ── GALLERY SLIDER ── */
    var track   = document.getElementById('pp-track-' + sid);
    var counter = document.getElementById('pp-counter-' + sid);
    var pfill   = document.getElementById('pp-pfill-' + sid);
    var dotsEl  = document.getElementById('pp-dots-' + sid);
    var dots    = dotsEl ? Array.from(dotsEl.querySelectorAll('.pp-dot')) : [];
    var prevBtn = document.getElementById('pp-prev-' + sid);
    var nextBtn = document.getElementById('pp-next-' + sid);
    var zoomBtn = document.getElementById('pp-zoom-' + sid);
    var total   = track ? track.children.length : 0;
    var cur     = 0;

    function goTo(idx) {
      if (!total) return;
      cur = ((idx % total) + total) % total;
      track.style.transform = 'translateX(-' + (cur * 100) + '%)';
      if (counter) counter.textContent = (cur + 1) + ' / ' + total;
      if (pfill) pfill.style.width = ((cur + 1) / total * 100) + '%';
      dots.forEach(function (d, i) { d.classList.toggle('is-active', i === cur); });
    }

    if (prevBtn) prevBtn.addEventListener('click', function () { goTo(cur - 1); });
    if (nextBtn) nextBtn.addEventListener('click', function () { goTo(cur + 1); });
    dots.forEach(function (d) {
      d.addEventListener('click', function () { goTo(parseInt(d.getAttribute('data-idx'), 10)); });
    });

    if (track) {
      var sx = null;
      track.addEventListener('touchstart', function (e) { sx = e.touches[0].clientX; }, { passive: true });
      track.addEventListener('touchend', function (e) {
        if (sx === null) return;
        var dx = e.changedTouches[0].clientX - sx;
        if (Math.abs(dx) > 40) goTo(dx < 0 ? cur + 1 : cur - 1);
        sx = null;
      }, { passive: true });
    }

    if (zoomBtn && track) {
      zoomBtn.addEventListener('click', function () {
        var img = track.children[cur] && track.children[cur].querySelector('img');
        if (!img) return;
        var w = window.open('', '_blank', 'noopener');
        w.document.write('<body style="margin:0;background:#111;display:flex;align-items:center;justify-content:center;min-height:100vh;cursor:zoom-out" onclick="window.close()"><img src="' + img.src + '" style="max-width:100vw;max-height:100vh;object-fit:contain"></body' + '>');
      });
    }

    /* ── ATC (AJAX) ── */
    var form   = document.getElementById('ppf-' + sid);
    var atcBtn = document.getElementById('pp-atc-' + sid);
    var varSel = document.getElementById('pp-varsel-' + sid);

    if (form && atcBtn) {
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        if (atcBtn.disabled) return;
        var vid = varSel ? varSel.value : (form.querySelector('[name="id"]') || {}).value;
        if (!vid) return;
        var orig = atcBtn.textContent;
        atcBtn.textContent = 'Adding…'; atcBtn.disabled = true;
        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
          body: JSON.stringify({ id: parseInt(vid, 10), quantity: 1 })
        })
        .then(function (r) { return r.json(); })
        .then(function (d) {
          atcBtn.textContent = 'Added!';
          document.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true }));
          document.dispatchEvent(new CustomEvent('product:added', { bubbles: true, detail: d }));
          setTimeout(function () { atcBtn.disabled = false; atcBtn.textContent = orig; }, 2000);
        })
        .catch(function () { atcBtn.textContent = 'Error'; atcBtn.disabled = false; });
      });
    }

    /* ── VARIANT SWITCH ── */
    if (varSel) {
      varSel.addEventListener('change', function () {
        var o  = varSel.options[varSel.selectedIndex];
        var p  = parseInt(o.getAttribute('data-price'), 10) || 0;
        var cp = parseInt(o.getAttribute('data-compare'), 10) || 0;
        var av = o.getAttribute('data-available') === 'true';
        var fmt = function (c) {
          return '{{ cart.currency.symbol }}' + (c / 100).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
        };
        var amt = document.getElementById('pp-amt-' + sid);
        var cmp = document.getElementById('pp-cmp-' + sid);
        var sav = document.getElementById('pp-sav-' + sid);
        if (amt) amt.textContent = fmt(p);
        if (cp > p) {
          if (cmp) { cmp.style.display = ''; cmp.textContent = fmt(cp); }
          if (sav) { sav.style.display = ''; sav.textContent = Math.round((cp - p) * 100 / cp) + '% OFF'; }
        } else {
          if (cmp) cmp.style.display = 'none';
          if (sav) sav.style.display = 'none';
        }
        if (atcBtn) { atcBtn.disabled = !av; atcBtn.textContent = av ? 'Add to Cart' : 'Sold Out'; }
      });
    }

    /* ── WISHLIST ── */
    var wishBtn = document.getElementById('pp-wish-' + sid);
    if (wishBtn) {
      var pid = wishBtn.getAttribute('data-product');
      var wl  = JSON.parse(localStorage.getItem('ma_wishlist') || '[]');
      if (wl.indexOf(pid) > -1) wishBtn.classList.add('is-active');
      wishBtn.addEventListener('click', function () {
        var list = JSON.parse(localStorage.getItem('ma_wishlist') || '[]');
        var idx  = list.indexOf(pid);
        if (idx > -1) { list.splice(idx, 1); wishBtn.classList.remove('is-active'); }
        else { list.push(pid); wishBtn.classList.add('is-active'); }
        localStorage.setItem('ma_wishlist', JSON.stringify(list));
      });
    }

    /* ── DESCRIPTION TOGGLE ── */
    var descBtn = document.getElementById('pp-desc-btn-' + sid);
    var descEl  = document.getElementById('pp-desc-' + sid);
    if (descBtn && descEl) descBtn.addEventListener('click', function () { descEl.classList.toggle('is-open'); });

    /* ── ACCORDION ── */
    var acc = document.getElementById('pp-acc-' + sid);
    if (acc) {
      acc.querySelectorAll('.pp-acc-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var item    = btn.closest('.pp-acc-item');
          var wasOpen = item.classList.contains('is-open');
          acc.querySelectorAll('.pp-acc-item').forEach(function (i) { i.classList.remove('is-open'); });
          if (!wasOpen) item.classList.add('is-open');
        });
      });
    }

    /* ── RELATED CAROUSEL ── */
    var relTrack = document.getElementById('pp-rel-track-' + sid);
    var relPrev  = document.getElementById('pp-rprev-' + sid);
    var relNext  = document.getElementById('pp-rnext-' + sid);
    if (relTrack) {
      var ri     = 0;
      var rvis   = window.innerWidth < 900 ? 2 : 4;
      var rcards = relTrack.querySelectorAll('.pp-rel-card');
      var rmax   = Math.max(0, rcards.length - rvis);
      function slideRel(dir) {
        ri = Math.max(0, Math.min(rmax, ri + dir));
        var cw = rcards[0] ? rcards[0].offsetWidth + 16 : 0;
        relTrack.style.transform = 'translateX(-' + (ri * cw) + 'px)';
      }
      if (relPrev) relPrev.addEventListener('click', function () { slideRel(-1); });
      if (relNext) relNext.addEventListener('click', function () { slideRel(1); });
    }

    /* ── CONDITION MODAL ── */
    var modal     = document.getElementById('pp-cond-modal-' + sid);
    var condOpen  = document.getElementById('pp-cond-open-' + sid);
    var condClose = document.getElementById('pp-cond-close-' + sid);
    if (modal) {
      if (condOpen)  condOpen.addEventListener('click', function () { modal.classList.add('is-open'); });
      if (condClose) condClose.addEventListener('click', function () { modal.classList.remove('is-open'); });
      modal.addEventListener('click', function (e) { if (e.target === modal) modal.classList.remove('is-open'); });
      document.addEventListener('keydown', function (e) { if (e.key === 'Escape') modal.classList.remove('is-open'); });
    }

  })();
  </script>
